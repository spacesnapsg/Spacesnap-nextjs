{
  "name": "spacesnap-nextjs",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "test": "DOTENV_CONFIG_PATH=.env.testing tsx --test prisma/tests/db-constraints.test.ts lib/certificate-gating.test.ts lib/bookings.test.ts lib/bulk-orders.test.ts lib/purchases.test.ts lib/wallet.test.ts lib/check-ins.test.ts lib/training-enrollments.test.ts lib/training-sessions.test.ts lib/ratings.test.ts lib/training-credentials.test.ts lib/quiz-attempts.test.ts lib/certificate-signoffs.test.ts",
    "test:db:migrate": "DOTENV_CONFIG_PATH=.env.testing prisma migrate deploy",
    "test:db:seed": "DOTENV_CONFIG_PATH=.env.testing prisma db seed",
    "test:db:setup": "npm run test:db:migrate && npm run test:db:seed"
  },
  "dependencies": {
    "@auth/prisma-adapter": "^2.11.2",
    "@aws-sdk/client-s3": "^3.1090.0",
    "@aws-sdk/s3-request-presigner": "^3.1090.0",
    "@prisma/adapter-pg": "^7.8.0",
    "@prisma/client": "^7.8.0",
    "@tanstack/react-query": "^5.101.2",
    "bcryptjs": "^3.0.3",
    "lucide-react": "^1.25.0",
    "next": "16.2.10",
    "next-auth": "^5.0.0-beta.31",
    "prisma": "^7.8.0",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "recharts": "^3.9.2"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/bcryptjs": "^2.4.6",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "16.2.10",
    "tailwindcss": "^4",
    "tsx": "^4.23.1",
    "typescript": "^5"
  }
}
