# Environment variables declared in this file are NOT automatically loaded by Prisma.
# Please add `import "dotenv/config";` to your `prisma.config.ts` file, or use the Prisma CLI with Bun
# to load environment variables from .env files: https://pris.ly/prisma-config-env-vars.

# Prisma supports the native connection string format for PostgreSQL, MySQL, SQLite, SQL Server, MongoDB and CockroachDB.
# See the documentation for all the connection string options: https://pris.ly/d/connection-strings

DATABASE_URL="postgresql://username@localhost:5432/spacesnap_dev"

# Auth.js (NextAuth v5)
# Generate with: npx auth secret
AUTH_SECRET="replace-with-a-generated-secret"

# Cloudflare R2 (S3-compatible) — file storage, per the stack decision in
# AGENTS.md/CLAUDE1.md. First real consumer: lib/storage.ts, used by the
# tier2a_operator_signoff evidence-recording upload flow
# (lib/certificate-signoffs.ts). Without these set, presigned upload/view
# URLs cannot be generated and that flow's storage calls will throw.
R2_ACCOUNT_ID="replace-with-your-cloudflare-account-id"
R2_ACCESS_KEY_ID="replace-with-an-r2-api-token-access-key-id"
R2_SECRET_ACCESS_KEY="replace-with-the-r2-api-token-secret"
R2_BUCKET_NAME="spacesnap-dev"

# Stripe — booking creation charges real-time SGD via a PaymentIntent per
# booking (Sprint 3.5 write-path session, 2026-07-21). Use a test-mode secret
# key (sk_test_...) for local dev. See lib/stripe.ts.
STRIPE_SECRET_KEY="sk_test_replace-with-your-stripe-test-secret-key"

# Stripe publishable key — client-side card collection via Stripe Elements
# (components/StripeCardField.tsx). NEXT_PUBLIC_ because the browser needs it;
# it is inlined at build time, so restart the dev server (or rebuild) after
# changing it. Must be the test-mode key (pk_test_...) matching the secret
# key's account above.
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY="pk_test_replace-with-your-stripe-test-publishable-key"

# Stripe webhook signing secret (Sprint 6) — app/api/webhooks/stripe/route.ts,
# lib/stripe-webhooks.ts. In production this comes from the Stripe Dashboard's
# webhook endpoint config (or `stripe listen`'s own secret when testing via
# the Stripe CLI locally); any value works for local dev/test since signature
# verification is a local HMAC check against whatever secret this app itself
# was configured with, not a live round trip to Stripe.
STRIPE_WEBHOOK_SECRET="whsec_replace-with-your-stripe-webhook-signing-secret"
