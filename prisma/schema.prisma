// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client"
  output   = "../app/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// ---------------------------------------------------------------------------
// Enums
// ---------------------------------------------------------------------------

enum UserStatus {
  active
  suspended

  @@map("user_status")
}

enum CertificateSource {
  platform
  supplier_created

  @@map("certificate_source")
}

enum CertificateStatus {
  pending
  approved
  rejected

  @@map("certificate_status")
}

// How a certificate is earned — distinct from `Certificate.category`, which
// is a different, existing classification (safety/equipment/house-rules per
// CODEBASE_SUMMARY.md). Do not conflate the two. There is no numeric
// progression between these three: each is just a different earning path,
// all producing the same kind of `user_certificates` row.
enum CertificateEarningMethod {
  tier1_video_quiz
  tier2a_operator_signoff
  tier2b_operator_or_sme_signoff

  @@map("certificate_earning_method")
}

enum ListingType {
  space
  equipment
  consumables

  @@map("listing_type")
}

enum BookingType {
  daily
  weekly
  monthly

  @@map("booking_type")
}

enum BookingStatus {
  pending
  confirmed
  active
  completed
  cancelled

  @@map("booking_status")
}

enum BulkOrderStatus {
  pending
  confirmed
  fulfilled
  cancelled

  @@map("bulk_order_status")
}

// Scoped 2026-07-20 (product owner): confirming a bulk order places a hold on
// the buyer's credits — reserved but not yet debited, since the real debit
// still only happens at fulfillment (fulfillBulkOrderWithDebit). Deliberately
// a separate table, not a Transaction row: Transaction represents money that
// actually moved (see its own comment below), a hold is a reservation against
// money that hasn't moved yet. "Available" balance = live Transaction SUM
// minus the user's own active, non-expired holds (lib/credit-holds.ts).
enum CreditHoldStatus {
  active
  released

  @@map("credit_hold_status")
}

// topup/refund are credit-direction, booking/purchase are debit-direction —
// amount sign still carries the actual direction, this just makes the ledger
// readable instead of overloading `booking` for both the original debit and
// the decline-refund credit like the old schema did.
//
// 2026-07-20 — purchased/earned balance split (MAS Payment Services Act
// exposure fix): a single combined wallet lets purchased (SGD top-up) credit
// pay a third-party operator's booking, which this product cannot do. Two
// independent, non-interchangeable balances replace the combined one, each
// computed live off this same ledger (never stored denormalized, same
// principle as the pre-split design — see Transaction model comment below),
// just partitioned by type instead of summed as one bucket:
//   purchasedBalance = SUM(amount) WHERE type IN (purchased_topup, purchased_spend)
//   earnedBalance    = SUM(amount) WHERE type IN (earned_grant, earned_spend)
// purchased_topup/purchased_spend: bought with SGD, spendable ONLY on
//   SpaceSnap's own goods/services (consumables from SpaceSnap's own stock,
//   certification fees, gig-posting fees) — never on a booking.
// earned_grant/earned_spend: never purchased, only issued as a reward
//   (booking activity, referrals, gig-completion payouts, operator
//   promotional allocations); spendable as a discount on bookings, on
//   consumables, or a gig worker's payout choice.
// booking_payment: the real-time SGD/Stripe charge for a booking (full
//   price). Deliberately outside both balance sums above — it never touches
//   either balance directly, only records the charge for audit parity with
//   every other credit-affecting event in this ledger. An earned_spend row
//   on the same booking is what actually carries an earned-balance discount.
// The old topup/booking/refund/purchase values are kept, not removed, since
// the write paths that still use them (booking create/confirm/decline,
// bulk-order fulfillment, Buy Now) haven't been rewired to the split model
// yet — that's Sprint 3.5/6 execution work, tracked in
// SPRINT_PLAN_NEXTJS_REWRITE.md, not part of this schema change. New code
// should use the five new values below, not the old four.
//
// 2026-07-21 — consumables + gigs extension, inspected against the
// paragraph above before adding anything (per this session's own "confirm
// no duplication" instruction): earned_spend/earned_grant/purchased_spend
// were all written last session already anticipating this work —
// purchased_spend's own doc explicitly lists "gig-posting fees", and
// earned_grant/earned_spend's explicitly lists "gig-completion payouts" and
// "a gig worker's payout choice". So none of earned_spend_booking,
// earned_spend_consumable, earned_grant_gig, or gig_purchase_spend get
// added — they'd duplicate existing generic values, disambiguated instead
// by which FK is set on the row (bookingId vs purchaseId vs gigTaskId) or
// by GigAssignment.payoutChoice. The one genuinely new case: a worker
// choosing direct SGD instead of earned credit is money leaving SpaceSnap
// to a member, which nothing existing represents (booking_payment is money
// coming in) — that's the only addition below.
enum TransactionType {
  topup
  booking
  refund
  purchase

  purchased_topup
  purchased_spend
  earned_grant
  earned_spend
  booking_payment

  gig_payout_sgd

  // Sprint 4.75 addition (2026-07-21) — the 20% fee charged when a user
  // reschedules a booking 3-7 days before its (pre-modification) start date.
  // Distinct from booking_payment (the original full-price charge): reusing
  // that value would conflate "what the stay costs" with "what rescheduling
  // it cost," which is a genuinely different ledger event, same reasoning as
  // why gig_payout_sgd got its own value above instead of overloading an
  // existing one. See calculateModificationTerms, lib/booking-payments.ts,
  // and modifyBookingWithFee, lib/bookings.ts.
  booking_modification_fee

  @@map("transaction_type")
}

// Confirmed against what lib/bookings.ts, lib/bulk-orders.ts, lib/wallet.ts,
// and lib/check-ins.ts actually do this sprint, not invented ahead of the
// write-paths that populate them. One value per hooked action, not a generic
// "booking" bucket, so the eventual feed can render each row without
// re-deriving what happened from the description string.
enum ActivityActionType {
  booking_created
  booking_confirmed
  booking_declined
  booking_cancelled
  booking_modified
  bulk_order_created
  bulk_order_confirmed
  bulk_order_declined
  bulk_order_fulfilled
  bulk_order_cancelled
  bulk_order_cancellation_requested
  bulk_order_cancellation_approved
  bulk_order_cancellation_rejected
  wallet_topup
  check_in
  check_out
  training_enrolled
  quiz_attempt_submitted
  credential_issued
  signoff_requested
  signoff_reviewed
  instant_purchase_completed
  training_waitlisted
  training_waitlist_approved
  training_session_created
  booking_completed
  bulk_order_confirmed_despite_insufficient_credit

  @@map("activity_action_type")
}

// waitlisted (2026-07-20 product owner decision): enrollUser never rejects
// once a session is at capacity — it enrolls into this status instead. Only
// a supplier PATCH (updateEnrollmentStatus) can promote waitlisted -> enrolled;
// there is no other path back to "enrolled" (see the InvalidEnrollmentStatusTransitionError
// guard in lib/training-enrollments.ts), same as before this status existed.
enum TrainingEnrollmentStatus {
  enrolled
  waitlisted
  awaiting_signoff
  completed
  cancelled

  @@map("training_enrollment_status")
}

// Sprint 4, Item 4 — the tier2a_operator_signoff earning path. Distinct from
// TrainingEnrollmentStatus/TrainingSession: tier2a is an on-demand, per-user
// request handled directly by an operator, not a scheduled multi-participant
// session (that's tier2b, which stays on training_enrollments). Confirmed
// with the product owner after an initial build wrongly conflated the two —
// see CLAUDE1.md "Sprint 4, Item 4, Correction."
enum SignoffSubmissionType {
  recording
  live_demo_request

  @@map("signoff_submission_type")
}

// pending -> passed | live_demo_requested (recording review can only pass or
//   escalate — an operator can never hard-fail someone off a recording
//   alone, confirmed with the product owner)
// pending -> passed | failed (live_demo_request: the demo already happened,
//   so a direct pass/fail call is possible)
// live_demo_requested -> passed | failed (after the follow-up live demo)
// See lib/certificate-signoffs.ts for the enforced transition table.
enum SignoffRequestStatus {
  pending
  live_demo_requested
  passed
  failed

  @@map("signoff_request_status")
}

// 2026-07-21 — gigs, new minimal scope (confirmed via grep of this repo and
// the old Laravel codebase: neither ever had gig tables/routes before this).
// Mirrors BulkOrderStatus's shape (pending/confirmed/fulfilled/cancelled)
// but with gig-specific labels — a task is `open` until a worker is
// assigned, not "pending" (which in this schema's other enums means
// "awaiting supplier action on something already submitted").
enum GigTaskStatus {
  open
  assigned
  completed
  cancelled

  @@map("gig_task_status")
}

// The worker's choice at assignment time for how GigAssignment.payoutAmount
// gets settled at completion — see the TransactionType comment above for
// which existing ledger value each choice maps to (earned_grant vs the new
// gig_payout_sgd).
enum GigPayoutChoice {
  earned_credit
  sgd

  @@map("gig_payout_choice")
}

// 2026-07-21 write-path session — a discount request must resolve against a
// specific, server-issued grant, never a client-supplied dollar amount or a
// pooled earnedBalance sum (that pooled sum still exists for internal
// reporting, see getEarnedBalance's comment in lib/credits.ts, but nothing
// redeems against it directly as of this session). One value per reward
// flavor implied by earlier sessions' comments ("10% off your next booking",
// "1 free consumables pack", gig payout choice already schema'd via
// GigAssignment.payoutChoice) — not a general-purpose rule engine, and no
// issuance logic beyond what those three already imply (see lib/reward-grants.ts).
enum RewardGrantType {
  booking_discount_pct
  free_consumable_unit
  gig_payout_credit

  @@map("reward_grant_type")
}

enum RewardGrantStatus {
  available
  redeemed
  expired

  @@map("reward_grant_status")
}

// Merchant-of-record, direct-charge cancellation policy — which party
// cancelled a booking. Whichever party did NOT cause the cancellation is made
// whole; only the at-fault party's outcome follows the days-before-
// session-start tier (see lib/booking-payments.ts):
//   - Supplier-initiated (decline): userRefundPercent is always 100 (the user
//     didn't cause this). supplierPenaltyPercent follows the day tier
//     (0/50/100) and is applied against SpaceSnap's commission portion of the
//     booking, not the full booking value.
//   - User-initiated (cancel): userRefundPercent follows the day tier
//     (100/50/0). supplierPenaltyPercent is always 0 (the supplier didn't
//     cause this — they still get their full normal payout).
// Both fields are nullable because most bookings are never cancelled at all.
// Confirmed with the product owner 2026-07-21, correcting this session's
// earlier (unconfirmed) assumption that the day tier applied to
// userRefundPercent regardless of who cancelled — see CLAUDE1.md.
enum BookingCancelledBy {
  user
  supplier

  @@map("booking_cancelled_by")
}

// A bounded credit note issued to a user when their booking is cancelled
// under a policy that doesn't fully refund to the original Stripe charge (or
// whatever future policy decides to issue one instead of/alongside a Stripe
// refund — that resolution logic is not built this session, only the ledger
// shape it will write to). Deliberately NOT a wallet top-up: it can only ever
// be redeemed against one specific future booking, has its own expiry, and
// is never summed into purchasedBalance/earnedBalance (see
// getPurchasedBalance/getEarnedBalance, lib/credits.ts) — do not merge this
// into that balance calculation.
enum BookingCreditStatus {
  available
  applied
  expired

  @@map("booking_credit_status")
}

model BookingCredit {
  id                 BigInt              @id @default(autoincrement())
  userId             String              @map("user_id")
  sourceBookingId    BigInt              @map("source_booking_id")
  amount             Decimal             @db.Decimal(10, 2)
  status             BookingCreditStatus @default(available)
  appliedToBookingId BigInt?             @map("applied_to_booking_id")
  expiresAt          DateTime            @map("expires_at")
  createdAt          DateTime            @default(now()) @map("created_at")

  user             User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  sourceBooking    Booking  @relation("BookingCreditSource", fields: [sourceBookingId], references: [id], onDelete: Cascade)
  appliedToBooking Booking? @relation("BookingCreditAppliedTo", fields: [appliedToBookingId], references: [id], onDelete: SetNull)

  @@map("booking_credits")
}

// What SpaceSnap owes a supplier, under the merchant-of-record model — the
// supplier is never paid directly by Stripe (SpaceSnap is always the
// merchant of record on the per-booking charge), so this is the ledger
// SpaceSnap's own accounts-payable process reads from to actually pay the
// supplier out, on whatever cadence their tier gets invoiced on.
//
// One row per booking (bookingId unique), but NOT one row per booking that
// exists — only for a booking that actually produced a financial event for
// the supplier ledger:
//   - Normal completion (check-out flips active -> completed): a credit row,
//     grossAmount = sgdAmount - commission, penaltyDeduction 0, netAmount =
//     grossAmount. See createCompletedBookingPayable, lib/supplier-payables.ts.
//   - Supplier-initiated decline with a non-zero cancellation-window
//     penalty: a pure DEBIT row — grossAmount 0 (the booking earned nothing,
//     the user was refunded in full), penaltyDeduction > 0, netAmount =
//     -penaltyDeduction. See declineBookingWithRefund, lib/bookings.ts.
//   - User-initiated cancel, or a supplier decline with zero penalty
//     (>=7 days out): a zero-effect audit row (all three amounts 0) — the
//     supplier is unaffected, not "still paid for a booking whose service
//     was never rendered."
// A company's actual pending payable balance is never read off a single
// row — it's the live SUM(netAmount) across all of a company's `pending`
// rows (getSupplierPendingPayableBalance, lib/supplier-payables.ts), same
// "never stored denormalized" principle as the Transaction ledger. This is
// what lets a supplier-cancellation penalty on one booking net against
// earnings from other, unrelated bookings automatically — no explicit
// "check the balance, then deduct" step is needed anywhere; the SUM already
// reflects it, and can go negative (supplier owes SpaceSnap back) if
// penalties exceed pending earnings.
enum SupplierPayableStatus {
  pending
  invoiced
  paid

  @@map("supplier_payable_status")
}

// Snapshot of Company.supplierTier's cadence AT THE TIME this payable was
// created — deliberately not a live join to Company, so a mid-cycle tier
// change never reaches back and reshuffles a payable that's already pending/
// invoiced. Which cadence each SupplierTier value actually maps to is not
// decided this session (see SupplierTier's own comment on Company below) —
// whatever future session builds the write path that creates SupplierPayable
// rows resolves that mapping, this column just holds the result.
enum InvoicingCadence {
  monthly
  biweekly
  weekly

  @@map("invoicing_cadence")
}

model SupplierPayable {
  id               BigInt                @id @default(autoincrement())
  companyId        BigInt                @map("company_id")
  bookingId        BigInt                @unique @map("booking_id")
  grossAmount      Decimal               @map("gross_amount") @db.Decimal(10, 2)
  penaltyDeduction Decimal               @default(0) @map("penalty_deduction") @db.Decimal(10, 2)
  netAmount        Decimal               @map("net_amount") @db.Decimal(10, 2)
  status           SupplierPayableStatus @default(pending)
  invoicingCadence InvoicingCadence      @map("invoicing_cadence")
  createdAt        DateTime              @default(now()) @map("created_at")

  company Company @relation(fields: [companyId], references: [id], onDelete: Cascade)
  booking Booking @relation(fields: [bookingId], references: [id], onDelete: Cascade)

  @@map("supplier_payables")
}

// A grant is issued with its own resolved type+value (e.g. `booking_discount_pct`
// value 10 = 10% off) and can only ever be redeemed once, atomically with the
// booking/purchase it discounts — see redeemRewardGrant (lib/reward-grants.ts),
// which flips status via an updateMany WHERE status:'available' guard so a
// race between two concurrent redemption attempts can't double-spend the same
// grant. grantedVia is a loose free-text label (e.g. "booking", "referral",
// "gig"), not an FK — no issuing flow exists yet for any of these, so there's
// nothing concrete to reference back to.
model RewardGrant {
  id         BigInt            @id @default(autoincrement())
  userId     String            @map("user_id")
  type       RewardGrantType
  value      Decimal           @db.Decimal(10, 2)
  status     RewardGrantStatus @default(available)
  grantedVia String            @map("granted_via")
  redeemedAt DateTime?         @map("redeemed_at")
  createdAt  DateTime          @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  transactions Transaction[]

  @@index([userId, status])
  @@map("reward_grants")
}

// ---------------------------------------------------------------------------
// Auth.js (NextAuth v5) — required by @auth/prisma-adapter, session strategy
// "database" per auth.ts. Model names must stay User/Account/Session/
// VerificationToken so the adapter's p.user/p.account/... calls resolve.
// ---------------------------------------------------------------------------

model Account {
  id                String  @id @default(cuid())
  userId            String  @map("user_id")
  type              String
  provider          String
  providerAccountId String  @map("provider_account_id")
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@map("accounts")
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique @map("session_token")
  userId       String   @map("user_id")
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("sessions")
}

model VerificationToken {
  identifier String
  token      String
  expires    DateTime

  @@unique([identifier, token])
  @@map("verification_tokens")
}

// ---------------------------------------------------------------------------
// Domain
// ---------------------------------------------------------------------------

// Manually settable by admin only — no automatic gating logic (rating/
// availability/booking-count thresholds) is built here, those numbers are
// still TBC. See the stubbed admin-route TODO in CLAUDE1.md's session note
// for this field; no route was added this session (schema + lib functions
// only, per this session's scope).
enum SupplierTier {
  free
  preferred
  top

  @@map("supplier_tier")
}

model Company {
  id                   BigInt       @id @default(autoincrement())
  name                 String
  businessName         String?      @map("business_name")
  businessDescription  String?      @map("business_description")
  contactEmail         String?      @map("contact_email")
  businessLocation     String?      @map("business_location")
  yearsOperating       Int?         @map("years_operating")
  // Added for the supplier profile "Business Details" edit form — the
  // registration number and finance contact fields the old CODEBASE_SUMMARY.md
  // gap note said had no backing columns at all (distinct from contactEmail,
  // which is the company's general contact address, not accounts/finance).
  registrationNumber   String?      @map("registration_number")
  financeContactEmail  String?      @map("finance_contact_email")
  financeContactPerson String?      @map("finance_contact_person")
  supplierTier         SupplierTier @default(free) @map("supplier_tier")
  createdAt            DateTime     @default(now()) @map("created_at")
  updatedAt            DateTime     @updatedAt @map("updated_at")

  users            User[]
  listings         Listing[]
  certificates     Certificate[]
  trainingVideos   TrainingVideo[]
  trainingSessions TrainingSession[]
  supplierPayables SupplierPayable[]

  @@map("companies")
}

// Role is derived from the three booleans, never a single enum column —
// carried over deliberately from the old schema (see AGENTS/CODEBASEAPI_SUMMARY §6).
// is_verified is intentionally NOT included: it was a half-built admin-review
// concept in the old app with no defined trigger or enforcement.
// Capabilities are additive (company admin implies supplier), enforced by the
// `users_company_admin_requires_supplier` CHECK constraint added in migration
// 20260718192008_users_company_admin_requires_supplier (raw SQL — Prisma
// can't express cross-column CHECK constraints natively).
model User {
  id                     String     @id @default(cuid())
  name                   String
  email                  String     @unique
  emailVerified          DateTime?  @map("email_verified")
  password               String
  title                  String?
  avatarUrl              String?    @map("avatar_url")
  isSupplier             Boolean    @default(false) @map("is_supplier")
  isCompanyAdmin         Boolean    @default(false) @map("is_company_admin")
  isSystemAdmin          Boolean    @default(false) @map("is_system_admin")
  companyId              BigInt?    @map("company_id")
  promotionRequested     Boolean    @default(false) @map("promotion_requested")
  stripeCustomerId       String?    @map("stripe_customer_id")
  stripeConnectAccountId String?    @map("stripe_connect_account_id")
  status                 UserStatus @default(active)
  createdAt              DateTime   @default(now()) @map("created_at")
  updatedAt              DateTime   @updatedAt @map("updated_at")

  company Company? @relation(fields: [companyId], references: [id], onDelete: SetNull)

  accounts Account[]
  sessions Session[]

  reviewedCertificates    Certificate[]               @relation("CertificateReviewer")
  userCertificates        UserCertificate[]
  signoffRequests         CertificateSignoffRequest[]
  reviewedSignoffRequests CertificateSignoffRequest[] @relation("SignoffReviewer")
  videoCompletions        VideoCompletion[]
  bookings                Booking[]
  bulkOrderRequests       BulkOrderRequest[]
  purchases               Purchase[]
  transactions            Transaction[]
  checkIns                CheckIn[]
  activityLogs            ActivityLog[]
  trainingEnrollments     TrainingEnrollment[]
  ratings                 Rating[]
  quizAttempts            QuizAttempt[]
  creditHolds             CreditHold[]
  postedGigTasks          GigTask[]                   @relation("GigTaskPoster")
  gigAssignments          GigAssignment[]             @relation("GigAssignmentWorker")
  rewardGrants            RewardGrant[]
  bookingCredits          BookingCredit[]

  @@map("users")
}

// App-layer rule (not DB-enforced yet): only status=approved certs may be
// referenced by listing_required_certificates or user_certificates.
model Certificate {
  id                 BigInt                   @id @default(autoincrement())
  name               String
  icon               String?
  category           String?
  earningMethod      CertificateEarningMethod @default(tier1_video_quiz) @map("earning_method")
  submissionNotes    String?                  @map("submission_notes")
  source             CertificateSource        @default(platform)
  status             CertificateStatus        @default(approved)
  createdByCompanyId BigInt?                  @map("created_by_company_id")
  reviewedBy         String?                  @map("reviewed_by")
  reviewedAt         DateTime?                @map("reviewed_at")
  createdAt          DateTime                 @default(now()) @map("created_at")
  updatedAt          DateTime                 @updatedAt @map("updated_at")

  createdByCompany Company? @relation(fields: [createdByCompanyId], references: [id], onDelete: SetNull)
  reviewer         User?    @relation("CertificateReviewer", fields: [reviewedBy], references: [id], onDelete: SetNull)

  requiredForListings ListingRequiredCertificate[]
  userCertificates    UserCertificate[]
  trainingVideos      TrainingVideo[]
  trainingSessions    TrainingSession[]
  signoffRequests     CertificateSignoffRequest[]

  @@map("certificates")
}

// Pricing fields are nullable here because the day/week/month vs.
// per_unit+stock+pack_size split (space/equipment vs. consumables) is
// enforced by the `listings_pricing_matches_type` CHECK constraint added in
// migration 20260718171756_listings_pricing_check (raw SQL — Prisma can't
// express this cross-column rule natively).
model Listing {
  id              BigInt      @id @default(autoincrement())
  companyId       BigInt      @map("company_id")
  type            ListingType
  name            String
  location        String?
  description     String?
  imageUrl        String?     @map("image_url")
  amenities       Json?
  isAvailable     Boolean     @default(true) @map("is_available")
  requireApproval Boolean     @default(false) @map("require_approval")
  priceDay        Decimal?    @map("price_day") @db.Decimal(10, 2)
  priceWeek       Decimal?    @map("price_week") @db.Decimal(10, 2)
  priceMonth      Decimal?    @map("price_month") @db.Decimal(10, 2)
  pricePerUnit    Decimal?    @map("price_per_unit") @db.Decimal(10, 2)
  stockQuantity   Int?        @map("stock_quantity")
  packSize        String?     @map("pack_size")
  createdAt       DateTime    @default(now()) @map("created_at")
  updatedAt       DateTime    @updatedAt @map("updated_at")

  company Company @relation(fields: [companyId], references: [id], onDelete: Cascade)

  requiredCertificates ListingRequiredCertificate[]
  bookings             Booking[]
  bulkOrderRequests    BulkOrderRequest[]
  purchases            Purchase[]
  checkIns             CheckIn[]
  activityLogs         ActivityLog[]
  ratings              Rating[]

  @@map("listings")
}

model ListingRequiredCertificate {
  id            BigInt   @id @default(autoincrement())
  listingId     BigInt   @map("listing_id")
  certificateId BigInt   @map("certificate_id")
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  listing     Listing     @relation(fields: [listingId], references: [id], onDelete: Cascade)
  certificate Certificate @relation(fields: [certificateId], references: [id], onDelete: Cascade)

  @@unique([listingId, certificateId])
  @@map("listing_required_certificates")
}

// expiryDate nullable — renewal-by-video flow deferred, column ready (matches
// old schema note).
model UserCertificate {
  id            BigInt    @id @default(autoincrement())
  userId        String    @map("user_id")
  certificateId BigInt    @map("certificate_id")
  earnedDate    DateTime  @map("earned_date") @db.Date
  expiryDate    DateTime? @map("expiry_date") @db.Date
  createdAt     DateTime  @default(now()) @map("created_at")
  updatedAt     DateTime  @updatedAt @map("updated_at")

  user        User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  certificate Certificate @relation(fields: [certificateId], references: [id], onDelete: Cascade)

  @@unique([userId, certificateId])
  @@map("user_certificates")
}

// companyId nullable = platform-authored. certificateId nullable — most
// videos are informational only; only videos backing a tier1_video_quiz
// certificate's self-serve earning path (Sprint 4, Item 4) have one set. Not
// enforced against Certificate.earningMethod at the DB level (same "app-layer
// rule, not a constraint" idiom as Certificate's own approved-only-if-
// referenced rule) — see lib/quiz-attempts.ts.
model TrainingVideo {
  id              BigInt   @id @default(autoincrement())
  companyId       BigInt?  @map("company_id")
  certificateId   BigInt?  @map("certificate_id")
  title           String
  category        String?
  description     String?
  durationSeconds Int?     @map("duration_seconds")
  videoUrl        String?  @map("video_url")
  thumbnailUrl    String?  @map("thumbnail_url")
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  company     Company?     @relation(fields: [companyId], references: [id], onDelete: SetNull)
  certificate Certificate? @relation(fields: [certificateId], references: [id], onDelete: SetNull)

  quizQuestions    QuizQuestion[]
  videoCompletions VideoCompletion[]
  quizAttempts     QuizAttempt[]

  @@map("training_videos")
}

// No createdAt/updatedAt on purpose — only completed_at, matches old schema.
model VideoCompletion {
  id              BigInt   @id @default(autoincrement())
  userId          String   @map("user_id")
  trainingVideoId BigInt   @map("training_video_id")
  completedAt     DateTime @map("completed_at")

  user          User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  trainingVideo TrainingVideo @relation(fields: [trainingVideoId], references: [id], onDelete: Cascade)

  @@unique([userId, trainingVideoId])
  @@map("video_completions")
}

model QuizQuestion {
  id              BigInt   @id @default(autoincrement())
  trainingVideoId BigInt   @map("training_video_id")
  question        String
  position        Int      @default(0)
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  trainingVideo TrainingVideo @relation(fields: [trainingVideoId], references: [id], onDelete: Cascade)
  answers       QuizAnswer[]

  @@map("quiz_questions")
}

// Exactly 4 answers / exactly 1 correct per question is an app-layer rule,
// not a DB constraint (matches old schema).
model QuizAnswer {
  id             BigInt   @id @default(autoincrement())
  quizQuestionId BigInt   @map("quiz_question_id")
  text           String
  isCorrect      Boolean  @default(false) @map("is_correct")
  position       Int      @default(0)
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")

  quizQuestion QuizQuestion @relation(fields: [quizQuestionId], references: [id], onDelete: Cascade)

  @@map("quiz_answers")
}

// companyId nullable, sme_name = subject-matter expert, endorsementName =
// display label carried over from the old schema (ported as-is). certificateId
// is new (Sprint 4, Item 4): the actual FK an enrollment's sign-off issues a
// credential against — endorsementName was never wired to real issuance logic
// in the old app (confirmed unbuilt, see CODEBASEAPI_SUMMARY.md §6), so a
// robust FK is used instead of runtime name-matching against
// Certificate.name (not unique). Nullable — not every session grants a cert.
model TrainingSession {
  id              BigInt   @id @default(autoincrement())
  companyId       BigInt?  @map("company_id")
  certificateId   BigInt?  @map("certificate_id")
  title           String
  smeName         String   @map("sme_name")
  description     String?
  sessionDatetime DateTime @map("session_datetime")
  location        String?
  endorsementName String?  @map("endorsement_name")
  capacity        Int
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  company     Company?     @relation(fields: [companyId], references: [id], onDelete: SetNull)
  certificate Certificate? @relation(fields: [certificateId], references: [id], onDelete: SetNull)

  enrollments TrainingEnrollment[]

  @@map("training_sessions")
}

// Overlap prevention is enforced by the `bookings_no_overlap` EXCLUDE USING
// gist constraint added in migration 20260718171742_bookings_no_overlap_exclude
// (raw SQL + btree_gist — Prisma can't express EXCLUDE natively). Any status
// other than `cancelled` holds the slot; only cancelled bookings are excluded
// from the overlap check.
//
// 2026-07-20: `credits` (a combined-wallet deduction) repurposed to
// `sgdAmount` — the purchased/earned balance split means a booking is no
// longer paid by deducting any wallet balance at all; it's charged in
// real-time SGD via Stripe (this field is the authoritative charge amount),
// with an optional earnedBalance discount recorded in `earnedCreditsApplied`.
// No purchasedBalance can ever be applied here — that's the whole point of
// the split, see TransactionType's purchased/earned comment. The actual
// Stripe-charge wiring (payment intent creation, earned-spend Transaction in
// the same DB transaction as the Booking create) is still on the old
// combined-ledger debit path as of this schema change — tracked as a
// Sprint 3.5 known gap in SPRINT_PLAN_NEXTJS_REWRITE.md, not rewired here.
//
// 2026-07-21: the gap above is closed — createBookingWithDebit (lib/bookings.ts)
// now creates a real Stripe PaymentIntent for `sgdAmount - earnedCreditsApplied`
// before opening the DB transaction. `earnedCreditsApplied` is resolved by
// redeeming a specific RewardGrant (type `booking_discount_pct`), never a raw
// client-supplied amount — see RewardGrant's own comment.
//
// 2026-07-21 — merchant-of-record, direct-charge cancellation fields. No
// duplicate stripePaymentIntentId column added here — Transaction already
// carries one (set on the booking_payment row createBookingWithDebit writes,
// see lib/bookings.ts), reused as-is rather than denormalizing a second copy
// onto Booking. userRefundPercent/supplierPenaltyPercent are populated by
// lib/booking-payments.ts's two pure calculator functions at whatever future
// cancellation-flow session actually sets cancelledAt/cancelledBy — not
// written by any code yet this session (schema only).
model Booking {
  id                        BigInt              @id @default(autoincrement())
  userId                    String              @map("user_id")
  listingId                 BigInt              @map("listing_id")
  bookingType               BookingType         @map("booking_type")
  startDate                 DateTime            @map("start_date") @db.Date
  endDate                   DateTime            @map("end_date") @db.Date
  sgdAmount                 Decimal             @map("sgd_amount") @db.Decimal(10, 2)
  earnedCreditsApplied      Decimal             @default(0) @map("earned_credits_applied") @db.Decimal(10, 2)
  // Snapshotted at booking creation (see PLATFORM_COMMISSION_PERCENT_BOOKINGS,
  // lib/booking-payments.ts), not a live constant read at cancellation time —
  // same "don't let a later rate change reshuffle an existing booking" design
  // as SupplierPayable.invoicingCadence. Confirmed with the product owner
  // 2026-07-21: flat 10% for space/equipment bookings (consumables/bulk
  // orders use a different, separately-scoped rate).
  platformCommissionPercent Decimal             @default(10) @map("platform_commission_percent") @db.Decimal(5, 2)
  status                    BookingStatus       @default(pending)
  cancelledAt               DateTime?           @map("cancelled_at")
  cancelledBy               BookingCancelledBy? @map("cancelled_by")
  cancellationReason        String?             @map("cancellation_reason")
  userRefundPercent         Decimal?            @map("user_refund_percent") @db.Decimal(5, 2)
  supplierPenaltyPercent    Decimal?            @map("supplier_penalty_percent") @db.Decimal(5, 2)
  // Sprint 4.75 addition (2026-07-21) — user-initiated reschedule
  // ("Modify Booking"), see modifyBookingWithFee (lib/bookings.ts) and
  // calculateModificationTerms (lib/booking-payments.ts).
  // originalStartDate is set once, the first time a booking is modified —
  // preserves the pre-modification date for history/audit display even
  // across repeat modifications; startDate/endDate above always hold the
  // CURRENT (possibly-modified) schedule and are what every other part of
  // this codebase (overlap check, cancellation-window day tiers) already
  // reads, unchanged.
  originalStartDate         DateTime?           @map("original_start_date") @db.Date
  // Set true the first time a modification lands in the 3-7 day fee tier
  // (per the product brief's own pseudocode — a free, >7-day-out
  // modification does not set this). Never reset back to false.
  isModified                Boolean             @default(false) @map("is_modified")
  // Caps this booking's OWN later user-initiated cancellation refund (the
  // "Refund Cap Engine": final % = min(standard day-tier %, this value)) —
  // see cancelBookingWithRefund, lib/bookings.ts. Null means uncapped
  // (a never-modified booking behaves exactly as before this feature).
  // Re-set on every modification per the tier that modification landed in
  // (a later free modification restores it to 100, not left at a stale 50).
  maxRefundablePercent      Decimal?            @map("max_refundable_percent") @db.Decimal(5, 2)
  createdAt                 DateTime            @default(now()) @map("created_at")
  updatedAt                 DateTime            @updatedAt @map("updated_at")

  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  listing Listing @relation(fields: [listingId], references: [id], onDelete: Cascade)

  transactions         Transaction[]
  checkIns             CheckIn[]
  rating               Rating?
  bookingCreditsIssued BookingCredit[]  @relation("BookingCreditSource")
  bookingCreditsSpent  BookingCredit[]  @relation("BookingCreditAppliedTo")
  supplierPayable      SupplierPayable?

  @@map("bookings")
}

// New feature (not a port from the old Laravel API — no Review/Rating
// concept existed there). One rating per booking (not per listing), so a
// user booking the same listing multiple times can rate each stay
// separately. listingId is denormalized off the booking at creation time so
// average/count aggregates don't need a join through bookings. score is
// constrained to 1-5 by a CHECK constraint (see the migration), matching
// the star-rating UI already in components/RatingStars.tsx.
model Rating {
  id        BigInt   @id @default(autoincrement())
  bookingId BigInt   @unique @map("booking_id")
  userId    String   @map("user_id")
  listingId BigInt   @map("listing_id")
  score     Int
  comment   String?
  createdAt DateTime @default(now()) @map("created_at")

  booking Booking @relation(fields: [bookingId], references: [id], onDelete: Cascade)
  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  listing Listing @relation(fields: [listingId], references: [id], onDelete: Cascade)

  @@map("ratings")
}

// Activity feed row for one hooked action. Sprint 3.5 new schema item — see
// SPRINT_PLAN_NEXTJS_REWRITE.md's Sprint 3.5 "new schema items" list. No
// updatedAt: rows are append-only, never edited after insert, unlike every
// other model in this file. relatedListingId is nullable because not every
// hooked action ties to a listing (wallet_topup doesn't). No feed UI yet —
// this sprint only wires the write path; verify by querying this table
// directly after performing a hooked action.
model ActivityLog {
  id               BigInt             @id @default(autoincrement())
  userId           String             @map("user_id")
  actionType       ActivityActionType @map("action_type")
  description      String
  relatedListingId BigInt?            @map("related_listing_id")
  createdAt        DateTime           @default(now()) @map("created_at")

  user    User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  listing Listing? @relation(fields: [relatedListingId], references: [id], onDelete: SetNull)

  @@map("activity_log")
}

// Consumables-only counterpart to Booking. Unlike the old Laravel schema,
// this rewrite never supported anonymous requests (no requester_name/
// requester_email — auth was already required by the time this table was
// designed, so those legacy-only columns aren't recreated here; see
// CODEBASEAPI_SUMMARY.md §6 "Fixed during recent sprints"). `credits` is
// NOT NULL from the start (computed at creation, cost = pricePerUnit *
// quantity) — the old schema only reached NOT NULL after a backfill
// migration; this rewrite starts there directly.
model BulkOrderRequest {
  id                      BigInt          @id @default(autoincrement())
  userId                  String          @map("user_id")
  listingId               BigInt          @map("listing_id")
  quantity                Int
  credits                 Decimal         @db.Decimal(10, 2)
  status                  BulkOrderStatus @default(pending)
  // Required at confirm time (2026-07-20 product owner request) — the
  // supplier's estimate of when the order will ship, shown to the buyer.
  // Nullable at the DB level only because pre-existing rows predate this
  // column; app-layer validation requires it on every confirm going forward.
  estimatedDeliveryDate   DateTime?       @map("estimated_delivery_date")
  // Cancellation-request pair, set together and cleared together — 2026-07-20
  // product owner request. Only meaningful while status is `confirmed`: a
  // `pending` request can be cancelled directly by the buyer (no review
  // needed, see cancelBulkOrderByUser in lib/bulk-orders.ts), but a
  // `confirmed` one has already had supplier attention, so the buyer can only
  // ask — the supplier approves (→ cancelled) or rejects (both fields
  // cleared, status stays confirmed).
  cancellationRequestedAt DateTime?       @map("cancellation_requested_at")
  cancellationReason      String?         @map("cancellation_reason")
  createdAt               DateTime        @default(now()) @map("created_at")
  updatedAt               DateTime        @updatedAt @map("updated_at")

  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  listing Listing @relation(fields: [listingId], references: [id], onDelete: Cascade)

  transactions Transaction[]
  creditHold   CreditHold?

  @@map("bulk_order_requests")
}

// One hold per confirmed bulk order (unique bulkOrderRequestId) — a request
// only ever has one hold across its lifetime, created at confirm and released
// exactly once (fulfill/decline/cancellation-approved/lazy expiry). expiresAt
// is fixed at 7 days from creation (product owner decision, 2026-07-20); there
// is no scheduled job anywhere in this codebase, so expiry is enforced lazily
// — every read of a user's available balance first releases that user's own
// expired holds (see releaseExpiredHoldsForUser, lib/credit-holds.ts), not by
// a background process.
model CreditHold {
  id                 BigInt           @id @default(autoincrement())
  userId             String           @map("user_id")
  bulkOrderRequestId BigInt           @unique @map("bulk_order_request_id")
  amount             Decimal          @db.Decimal(10, 2)
  status             CreditHoldStatus @default(active)
  createdAt          DateTime         @default(now()) @map("created_at")
  expiresAt          DateTime         @map("expires_at")
  releasedAt         DateTime?        @map("released_at")

  user             User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  bulkOrderRequest BulkOrderRequest @relation(fields: [bulkOrderRequestId], references: [id], onDelete: Cascade)

  @@index([userId, status])
  @@map("credit_holds")
}

// "Buy Now" is deliberately NOT a BulkOrderRequest — a bulk order is a
// request the supplier still has to act on (pending/confirmed/fulfilled/
// cancelled); Buy Now is an immediate, already-completed sale: stock and
// credits move atomically at creation, there's no supplier-side status to
// transition. `stripePaymentIntentId` on Transaction is where the future
// Stripe invoice/receipt (user gets an invoice, supplier gets a receipt of
// funds — Sprint 6, not built here) will eventually hang; this model itself
// stays payment-provider-agnostic, same as every other credit-affecting
// model in this schema today.
// 2026-07-21: `earnedCreditsApplied` added — same pattern as
// Booking.earnedCreditsApplied (see that field's comment), an optional
// discount line against `credits` (this model's existing full-cost field,
// confirmed unchanged before adding — it was never called `cost`).
// `credits` still covers the full price via purchasedBalance as today;
// this is an additive discount option, not a replacement mechanic — a
// purchase can still be paid entirely from purchasedBalance with this at 0.
//
// 2026-07-21, same session: the write path is wired — createPurchaseWithDebit
// (lib/purchases.ts) now debits purchasedBalance for `credits - earnedCreditsApplied`
// (TransactionType.purchased_spend, replacing the old combined-ledger `purchase`
// type) and, when a RewardGrant (type `free_consumable_unit`) is redeemed,
// writes a matching earned_spend row. Unlike Booking, Purchase stays
// purchasedBalance-funded — consumables are SpaceSnap's own stock, not a
// third-party operator charge, so there's no compliance reason to route this
// through Stripe per-purchase (see TransactionType's purchased/earned comment).
model Purchase {
  id                   BigInt   @id @default(autoincrement())
  userId               String   @map("user_id")
  listingId            BigInt   @map("listing_id")
  quantity             Int
  credits              Decimal  @db.Decimal(10, 2)
  earnedCreditsApplied Decimal  @default(0) @map("earned_credits_applied") @db.Decimal(10, 2)
  createdAt            DateTime @default(now()) @map("created_at")

  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  listing Listing @relation(fields: [listingId], references: [id], onDelete: Cascade)

  transactions Transaction[]

  @@map("purchases")
}

// 2026-07-21 — gigs, schema only (no payment/payout logic here, same as the
// booking write-path deferral last session — see TransactionType comment
// above and the write-path gap tracked in SPRINT_PLAN_NEXTJS_REWRITE.md).
// purchasedSpend is what the poster pays SpaceSnap to post/fulfil the task —
// SpaceSnap is always principal, posting a task never pays another member
// directly (same pattern as every other purchased_spend event). No
// Transaction FK column added here (unlike Booking/BulkOrderRequest/
// Purchase) — deliberately deferred to the write-path session that actually
// creates these rows, not guessed at ahead of it.
model GigTask {
  id             BigInt        @id @default(autoincrement())
  posterId       String        @map("poster_id")
  description    String
  purchasedSpend Decimal       @map("purchased_spend") @db.Decimal(10, 2)
  status         GigTaskStatus @default(open)
  createdAt      DateTime      @default(now()) @map("created_at")
  updatedAt      DateTime      @updatedAt @map("updated_at")

  poster User @relation("GigTaskPoster", fields: [posterId], references: [id], onDelete: Cascade)

  assignments GigAssignment[]

  @@map("gig_tasks")
}

// One row per worker assigned to a GigTask. payoutAmount is the resolved
// SGD-equivalent value at completion regardless of payoutChoice — earned
// credits and SGD are two different settlement rails for the same amount,
// not two different prices. completedAt nullable: set only when the
// assignment finishes (status transition to GigTaskStatus.completed lives on
// the parent GigTask, not duplicated here).
model GigAssignment {
  id           BigInt          @id @default(autoincrement())
  gigTaskId    BigInt          @map("gig_task_id")
  workerId     String          @map("worker_id")
  payoutChoice GigPayoutChoice @map("payout_choice")
  payoutAmount Decimal         @map("payout_amount") @db.Decimal(10, 2)
  completedAt  DateTime?       @map("completed_at")
  createdAt    DateTime        @default(now()) @map("created_at")
  updatedAt    DateTime        @updatedAt @map("updated_at")

  gigTask GigTask @relation(fields: [gigTaskId], references: [id], onDelete: Cascade)
  worker  User    @relation("GigAssignmentWorker", fields: [workerId], references: [id], onDelete: Cascade)

  @@map("gig_assignments")
}

// The wallet ledger — balance is always SUM(amount) WHERE user_id = ?, never
// stored denormalized. bookingId/bulkOrderRequestId/purchaseId nullable
// (topups aren't tied to any of them). Supports one row per credit-affecting
// event (booking create debit, booking confirm, decline/refund credit,
// bulk-order purchase, instant purchase, topup) rather than the old app's
// single create-time-only row.
//
// 2026-07-20: `type` now also carries which of the two split balances a row
// belongs to (purchased_* vs earned_*) or neither (booking_payment) — see
// the purchased/earned balance-split comment on TransactionType above for
// the full reasoning and the two SUM formulas.
model Transaction {
  id                    BigInt          @id @default(autoincrement())
  userId                String          @map("user_id")
  bookingId             BigInt?         @map("booking_id")
  bulkOrderRequestId    BigInt?         @map("bulk_order_request_id")
  purchaseId            BigInt?         @map("purchase_id")
  // 2026-07-21: set on the earned_spend row a grant redemption writes (or, in
  // future, the earned_grant row an issuance flow writes) — ties the ledger
  // movement back to the specific RewardGrant it corresponds to, per that
  // model's own comment. Nullable: most Transaction rows (topups, purchased_spend,
  // booking_payment, refunds) have no grant involved at all.
  rewardGrantId         BigInt?         @map("reward_grant_id")
  type                  TransactionType
  amount                Decimal         @db.Decimal(10, 2)
  stripePaymentIntentId String?         @map("stripe_payment_intent_id")
  description           String?
  createdAt             DateTime        @default(now()) @map("created_at")
  updatedAt             DateTime        @updatedAt @map("updated_at")

  user             User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  booking          Booking?          @relation(fields: [bookingId], references: [id], onDelete: SetNull)
  bulkOrderRequest BulkOrderRequest? @relation(fields: [bulkOrderRequestId], references: [id], onDelete: SetNull)
  purchase         Purchase?         @relation(fields: [purchaseId], references: [id], onDelete: SetNull)
  rewardGrant      RewardGrant?      @relation(fields: [rewardGrantId], references: [id], onDelete: SetNull)

  @@map("transactions")
}

// Sprint 3.5 new schema item. bookingId nullable — not every check-in ties to
// a booking (e.g. a supplier logging a walk-in visit), so the status side
// effect below only applies when it's set. Per the sprint plan note ("the old
// app never had a working controller for this... should decide whether
// check-in updates booking status" — confirmed with the user before building,
// see CLAUDE1.md): check-in flips a `confirmed` booking to `active`,
// check-out flips `active` to `completed` — the two enum values with no other
// writer anywhere in this codebase. Enforced in lib/check-ins.ts, not a DB
// constraint (mirrors how Booking status guards on confirm/decline are
// app-layer, not DB-layer).
model CheckIn {
  id           BigInt    @id @default(autoincrement())
  userId       String    @map("user_id")
  listingId    BigInt    @map("listing_id")
  bookingId    BigInt?   @map("booking_id")
  checkedInAt  DateTime  @default(now()) @map("checked_in_at")
  checkedOutAt DateTime? @map("checked_out_at")

  user    User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  listing Listing  @relation(fields: [listingId], references: [id], onDelete: Cascade)
  booking Booking? @relation(fields: [bookingId], references: [id], onDelete: SetNull)

  @@map("check_ins")
}

// Sprint 3.5 new schema item — backs the training session "enrolled
// participants" list referenced by the Digital Passport / training pages
// (no roster UI built yet this sprint; see SPRINT_PLAN_NEXTJS_REWRITE.md
// Sprint 3.5). One row per user per session, enforced at the DB level (not
// just app-layer) by @@unique below — same "app-layer pre-check + DB
// constraint as race-condition fallback" idiom as bookings_no_overlap (see
// lib/training-enrollments.ts and app/api/bookings/route.ts's 23P01 catch;
// this one catches Postgres 23505 instead).
model TrainingEnrollment {
  id                BigInt                   @id @default(autoincrement())
  userId            String                   @map("user_id")
  trainingSessionId BigInt                   @map("training_session_id")
  status            TrainingEnrollmentStatus @default(enrolled)
  createdAt         DateTime                 @default(now()) @map("created_at")
  updatedAt         DateTime                 @updatedAt @map("updated_at")

  user            User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  trainingSession TrainingSession @relation(fields: [trainingSessionId], references: [id], onDelete: Cascade)

  @@unique([userId, trainingSessionId])
  @@map("training_enrollments")
}

// Sprint 4, Item 4 — the tier1_video_quiz earning path: a user's graded
// submission against a TrainingVideo's quiz. Auto-graded at submission time
// (no reviewer — that's what distinguishes tier1 from the tier2a/2b
// operator/SME sign-off path, which reuses training_enrollments' existing
// status column instead of this table, per the "don't invent new statuses"
// instruction for this item). Append-only like ActivityLog/VideoCompletion —
// retries create a new row rather than overwriting, so the user's full
// attempt history is visible, not just the latest result. No unique
// constraint on (userId, trainingVideoId): retakes after a fail are allowed.
// score/totalQuestions are a snapshot of that attempt's grading, independent
// of any later edits to the quiz's question set. See lib/quiz-attempts.ts.
model QuizAttempt {
  id              BigInt   @id @default(autoincrement())
  userId          String   @map("user_id")
  trainingVideoId BigInt   @map("training_video_id")
  score           Int
  totalQuestions  Int      @map("total_questions")
  passed          Boolean
  createdAt       DateTime @default(now()) @map("created_at")

  user          User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  trainingVideo TrainingVideo @relation(fields: [trainingVideoId], references: [id], onDelete: Cascade)

  @@map("quiz_attempts")
}

// Sprint 4, Item 4 — the tier2a_operator_signoff earning path (see
// SignoffSubmissionType/SignoffRequestStatus comments above). One row per
// (userId, certificateId), not append-only like QuizAttempt: a fresh
// submission after a terminal outcome (passed/failed) updates this same row
// rather than creating a new one, per the product owner's "one record per
// user certificate" instruction. recordingKey is an R2 object key
// (lib/storage.ts), not a public URL — evidence is reviewed, not displayed —
// and is only set when submissionType is `recording`.
model CertificateSignoffRequest {
  id             BigInt                @id @default(autoincrement())
  userId         String                @map("user_id")
  certificateId  BigInt                @map("certificate_id")
  submissionType SignoffSubmissionType @map("submission_type")
  recordingKey   String?               @map("recording_key")
  status         SignoffRequestStatus  @default(pending)
  reviewedBy     String?               @map("reviewed_by")
  reviewedAt     DateTime?             @map("reviewed_at")
  createdAt      DateTime              @default(now()) @map("created_at")
  updatedAt      DateTime              @updatedAt @map("updated_at")

  user        User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  certificate Certificate @relation(fields: [certificateId], references: [id], onDelete: Cascade)
  reviewer    User?       @relation("SignoffReviewer", fields: [reviewedBy], references: [id], onDelete: SetNull)

  @@unique([userId, certificateId])
  @@map("certificate_signoff_requests")
}
