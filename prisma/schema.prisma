// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client"
  output   = "../app/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// ---------------------------------------------------------------------------
// Enums
// ---------------------------------------------------------------------------

enum UserStatus {
  active
  suspended

  @@map("user_status")
}

enum CertificateSource {
  platform
  supplier_created

  @@map("certificate_source")
}

enum CertificateStatus {
  pending
  approved
  rejected

  @@map("certificate_status")
}

// How a certificate is earned — distinct from `Certificate.category`, which
// is a different, existing classification (safety/equipment/house-rules per
// CODEBASE_SUMMARY.md). Do not conflate the two. There is no numeric
// progression between these three: each is just a different earning path,
// all producing the same kind of `user_certificates` row.
enum CertificateEarningMethod {
  tier1_video_quiz
  tier2a_operator_signoff
  tier2b_operator_or_sme_signoff

  @@map("certificate_earning_method")
}

enum ListingType {
  space
  equipment
  consumables

  @@map("listing_type")
}

enum BookingType {
  daily
  weekly
  monthly

  @@map("booking_type")
}

enum BookingStatus {
  pending
  confirmed
  active
  completed
  cancelled

  @@map("booking_status")
}

enum BulkOrderStatus {
  pending
  confirmed
  fulfilled
  cancelled

  @@map("bulk_order_status")
}

// topup/refund are credit-direction, booking/purchase are debit-direction —
// amount sign still carries the actual direction, this just makes the ledger
// readable instead of overloading `booking` for both the original debit and
// the decline-refund credit like the old schema did.
enum TransactionType {
  topup
  booking
  refund
  purchase

  @@map("transaction_type")
}

// Confirmed against what lib/bookings.ts, lib/bulk-orders.ts, lib/wallet.ts,
// and lib/check-ins.ts actually do this sprint, not invented ahead of the
// write-paths that populate them. One value per hooked action, not a generic
// "booking" bucket, so the eventual feed can render each row without
// re-deriving what happened from the description string.
enum ActivityActionType {
  booking_created
  booking_confirmed
  booking_declined
  bulk_order_created
  bulk_order_confirmed
  bulk_order_declined
  bulk_order_fulfilled
  bulk_order_cancelled
  bulk_order_cancellation_requested
  bulk_order_cancellation_approved
  bulk_order_cancellation_rejected
  wallet_topup
  check_in
  check_out
  training_enrolled
  quiz_attempt_submitted
  credential_issued
  signoff_requested
  signoff_reviewed
  instant_purchase_completed
  training_waitlisted
  training_waitlist_approved
  training_session_created

  @@map("activity_action_type")
}

// waitlisted (2026-07-20 product owner decision): enrollUser never rejects
// once a session is at capacity — it enrolls into this status instead. Only
// a supplier PATCH (updateEnrollmentStatus) can promote waitlisted -> enrolled;
// there is no other path back to "enrolled" (see the InvalidEnrollmentStatusTransitionError
// guard in lib/training-enrollments.ts), same as before this status existed.
enum TrainingEnrollmentStatus {
  enrolled
  waitlisted
  awaiting_signoff
  completed
  cancelled

  @@map("training_enrollment_status")
}

// Sprint 4, Item 4 — the tier2a_operator_signoff earning path. Distinct from
// TrainingEnrollmentStatus/TrainingSession: tier2a is an on-demand, per-user
// request handled directly by an operator, not a scheduled multi-participant
// session (that's tier2b, which stays on training_enrollments). Confirmed
// with the product owner after an initial build wrongly conflated the two —
// see CLAUDE1.md "Sprint 4, Item 4, Correction."
enum SignoffSubmissionType {
  recording
  live_demo_request

  @@map("signoff_submission_type")
}

// pending -> passed | live_demo_requested (recording review can only pass or
//   escalate — an operator can never hard-fail someone off a recording
//   alone, confirmed with the product owner)
// pending -> passed | failed (live_demo_request: the demo already happened,
//   so a direct pass/fail call is possible)
// live_demo_requested -> passed | failed (after the follow-up live demo)
// See lib/certificate-signoffs.ts for the enforced transition table.
enum SignoffRequestStatus {
  pending
  live_demo_requested
  passed
  failed

  @@map("signoff_request_status")
}

// ---------------------------------------------------------------------------
// Auth.js (NextAuth v5) — required by @auth/prisma-adapter, session strategy
// "database" per auth.ts. Model names must stay User/Account/Session/
// VerificationToken so the adapter's p.user/p.account/... calls resolve.
// ---------------------------------------------------------------------------

model Account {
  id                String  @id @default(cuid())
  userId            String  @map("user_id")
  type              String
  provider          String
  providerAccountId String  @map("provider_account_id")
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@map("accounts")
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique @map("session_token")
  userId       String   @map("user_id")
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("sessions")
}

model VerificationToken {
  identifier String
  token      String
  expires    DateTime

  @@unique([identifier, token])
  @@map("verification_tokens")
}

// ---------------------------------------------------------------------------
// Domain
// ---------------------------------------------------------------------------

model Company {
  id                  BigInt   @id @default(autoincrement())
  name                String
  businessName        String?  @map("business_name")
  businessDescription String?  @map("business_description")
  contactEmail        String?  @map("contact_email")
  businessLocation    String?  @map("business_location")
  yearsOperating      Int?     @map("years_operating")
  createdAt           DateTime @default(now()) @map("created_at")
  updatedAt           DateTime @updatedAt @map("updated_at")

  users            User[]
  listings         Listing[]
  certificates     Certificate[]
  trainingVideos   TrainingVideo[]
  trainingSessions TrainingSession[]

  @@map("companies")
}

// Role is derived from the three booleans, never a single enum column —
// carried over deliberately from the old schema (see AGENTS/CODEBASEAPI_SUMMARY §6).
// is_verified is intentionally NOT included: it was a half-built admin-review
// concept in the old app with no defined trigger or enforcement.
// Capabilities are additive (company admin implies supplier), enforced by the
// `users_company_admin_requires_supplier` CHECK constraint added in migration
// 20260718192008_users_company_admin_requires_supplier (raw SQL — Prisma
// can't express cross-column CHECK constraints natively).
model User {
  id                     String     @id @default(cuid())
  name                   String
  email                  String     @unique
  emailVerified          DateTime?  @map("email_verified")
  password               String
  title                  String?
  avatarUrl              String?    @map("avatar_url")
  isSupplier             Boolean    @default(false) @map("is_supplier")
  isCompanyAdmin         Boolean    @default(false) @map("is_company_admin")
  isSystemAdmin          Boolean    @default(false) @map("is_system_admin")
  companyId              BigInt?    @map("company_id")
  promotionRequested     Boolean    @default(false) @map("promotion_requested")
  stripeCustomerId       String?    @map("stripe_customer_id")
  stripeConnectAccountId String?    @map("stripe_connect_account_id")
  status                 UserStatus @default(active)
  createdAt              DateTime   @default(now()) @map("created_at")
  updatedAt              DateTime   @updatedAt @map("updated_at")

  company Company? @relation(fields: [companyId], references: [id], onDelete: SetNull)

  accounts Account[]
  sessions Session[]

  reviewedCertificates    Certificate[]               @relation("CertificateReviewer")
  userCertificates        UserCertificate[]
  signoffRequests         CertificateSignoffRequest[]
  reviewedSignoffRequests CertificateSignoffRequest[] @relation("SignoffReviewer")
  videoCompletions        VideoCompletion[]
  bookings                Booking[]
  bulkOrderRequests       BulkOrderRequest[]
  purchases               Purchase[]
  transactions            Transaction[]
  checkIns                CheckIn[]
  activityLogs            ActivityLog[]
  trainingEnrollments     TrainingEnrollment[]
  ratings                 Rating[]
  quizAttempts            QuizAttempt[]

  @@map("users")
}

// App-layer rule (not DB-enforced yet): only status=approved certs may be
// referenced by listing_required_certificates or user_certificates.
model Certificate {
  id                 BigInt                   @id @default(autoincrement())
  name               String
  icon               String?
  category           String?
  earningMethod      CertificateEarningMethod @default(tier1_video_quiz) @map("earning_method")
  submissionNotes    String?                  @map("submission_notes")
  source             CertificateSource        @default(platform)
  status             CertificateStatus        @default(approved)
  createdByCompanyId BigInt?                  @map("created_by_company_id")
  reviewedBy         String?                  @map("reviewed_by")
  reviewedAt         DateTime?                @map("reviewed_at")
  createdAt          DateTime                 @default(now()) @map("created_at")
  updatedAt          DateTime                 @updatedAt @map("updated_at")

  createdByCompany Company? @relation(fields: [createdByCompanyId], references: [id], onDelete: SetNull)
  reviewer         User?    @relation("CertificateReviewer", fields: [reviewedBy], references: [id], onDelete: SetNull)

  requiredForListings ListingRequiredCertificate[]
  userCertificates    UserCertificate[]
  trainingVideos      TrainingVideo[]
  trainingSessions    TrainingSession[]
  signoffRequests     CertificateSignoffRequest[]

  @@map("certificates")
}

// Pricing fields are nullable here because the day/week/month vs.
// per_unit+stock+pack_size split (space/equipment vs. consumables) is
// enforced by the `listings_pricing_matches_type` CHECK constraint added in
// migration 20260718171756_listings_pricing_check (raw SQL — Prisma can't
// express this cross-column rule natively).
model Listing {
  id              BigInt      @id @default(autoincrement())
  companyId       BigInt      @map("company_id")
  type            ListingType
  name            String
  location        String?
  description     String?
  imageUrl        String?     @map("image_url")
  amenities       Json?
  isAvailable     Boolean     @default(true) @map("is_available")
  requireApproval Boolean     @default(false) @map("require_approval")
  priceDay        Decimal?    @map("price_day") @db.Decimal(10, 2)
  priceWeek       Decimal?    @map("price_week") @db.Decimal(10, 2)
  priceMonth      Decimal?    @map("price_month") @db.Decimal(10, 2)
  pricePerUnit    Decimal?    @map("price_per_unit") @db.Decimal(10, 2)
  stockQuantity   Int?        @map("stock_quantity")
  packSize        String?     @map("pack_size")
  createdAt       DateTime    @default(now()) @map("created_at")
  updatedAt       DateTime    @updatedAt @map("updated_at")

  company Company @relation(fields: [companyId], references: [id], onDelete: Cascade)

  requiredCertificates ListingRequiredCertificate[]
  bookings             Booking[]
  bulkOrderRequests    BulkOrderRequest[]
  purchases            Purchase[]
  checkIns             CheckIn[]
  activityLogs         ActivityLog[]
  ratings              Rating[]

  @@map("listings")
}

model ListingRequiredCertificate {
  id            BigInt   @id @default(autoincrement())
  listingId     BigInt   @map("listing_id")
  certificateId BigInt   @map("certificate_id")
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  listing     Listing     @relation(fields: [listingId], references: [id], onDelete: Cascade)
  certificate Certificate @relation(fields: [certificateId], references: [id], onDelete: Cascade)

  @@unique([listingId, certificateId])
  @@map("listing_required_certificates")
}

// expiryDate nullable — renewal-by-video flow deferred, column ready (matches
// old schema note).
model UserCertificate {
  id            BigInt    @id @default(autoincrement())
  userId        String    @map("user_id")
  certificateId BigInt    @map("certificate_id")
  earnedDate    DateTime  @map("earned_date") @db.Date
  expiryDate    DateTime? @map("expiry_date") @db.Date
  createdAt     DateTime  @default(now()) @map("created_at")
  updatedAt     DateTime  @updatedAt @map("updated_at")

  user        User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  certificate Certificate @relation(fields: [certificateId], references: [id], onDelete: Cascade)

  @@unique([userId, certificateId])
  @@map("user_certificates")
}

// companyId nullable = platform-authored. certificateId nullable — most
// videos are informational only; only videos backing a tier1_video_quiz
// certificate's self-serve earning path (Sprint 4, Item 4) have one set. Not
// enforced against Certificate.earningMethod at the DB level (same "app-layer
// rule, not a constraint" idiom as Certificate's own approved-only-if-
// referenced rule) — see lib/quiz-attempts.ts.
model TrainingVideo {
  id              BigInt   @id @default(autoincrement())
  companyId       BigInt?  @map("company_id")
  certificateId   BigInt?  @map("certificate_id")
  title           String
  category        String?
  description     String?
  durationSeconds Int?     @map("duration_seconds")
  videoUrl        String?  @map("video_url")
  thumbnailUrl    String?  @map("thumbnail_url")
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  company     Company?     @relation(fields: [companyId], references: [id], onDelete: SetNull)
  certificate Certificate? @relation(fields: [certificateId], references: [id], onDelete: SetNull)

  quizQuestions    QuizQuestion[]
  videoCompletions VideoCompletion[]
  quizAttempts     QuizAttempt[]

  @@map("training_videos")
}

// No createdAt/updatedAt on purpose — only completed_at, matches old schema.
model VideoCompletion {
  id              BigInt   @id @default(autoincrement())
  userId          String   @map("user_id")
  trainingVideoId BigInt   @map("training_video_id")
  completedAt     DateTime @map("completed_at")

  user          User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  trainingVideo TrainingVideo @relation(fields: [trainingVideoId], references: [id], onDelete: Cascade)

  @@unique([userId, trainingVideoId])
  @@map("video_completions")
}

model QuizQuestion {
  id              BigInt   @id @default(autoincrement())
  trainingVideoId BigInt   @map("training_video_id")
  question        String
  position        Int      @default(0)
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  trainingVideo TrainingVideo @relation(fields: [trainingVideoId], references: [id], onDelete: Cascade)
  answers       QuizAnswer[]

  @@map("quiz_questions")
}

// Exactly 4 answers / exactly 1 correct per question is an app-layer rule,
// not a DB constraint (matches old schema).
model QuizAnswer {
  id             BigInt   @id @default(autoincrement())
  quizQuestionId BigInt   @map("quiz_question_id")
  text           String
  isCorrect      Boolean  @default(false) @map("is_correct")
  position       Int      @default(0)
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")

  quizQuestion QuizQuestion @relation(fields: [quizQuestionId], references: [id], onDelete: Cascade)

  @@map("quiz_answers")
}

// companyId nullable, sme_name = subject-matter expert, endorsementName =
// display label carried over from the old schema (ported as-is). certificateId
// is new (Sprint 4, Item 4): the actual FK an enrollment's sign-off issues a
// credential against — endorsementName was never wired to real issuance logic
// in the old app (confirmed unbuilt, see CODEBASEAPI_SUMMARY.md §6), so a
// robust FK is used instead of runtime name-matching against
// Certificate.name (not unique). Nullable — not every session grants a cert.
model TrainingSession {
  id              BigInt   @id @default(autoincrement())
  companyId       BigInt?  @map("company_id")
  certificateId   BigInt?  @map("certificate_id")
  title           String
  smeName         String   @map("sme_name")
  description     String?
  sessionDatetime DateTime @map("session_datetime")
  location        String?
  endorsementName String?  @map("endorsement_name")
  capacity        Int
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  company     Company?     @relation(fields: [companyId], references: [id], onDelete: SetNull)
  certificate Certificate? @relation(fields: [certificateId], references: [id], onDelete: SetNull)

  enrollments TrainingEnrollment[]

  @@map("training_sessions")
}

// Overlap prevention is enforced by the `bookings_no_overlap` EXCLUDE USING
// gist constraint added in migration 20260718171742_bookings_no_overlap_exclude
// (raw SQL + btree_gist — Prisma can't express EXCLUDE natively). Any status
// other than `cancelled` holds the slot; only cancelled bookings are excluded
// from the overlap check.
model Booking {
  id          BigInt        @id @default(autoincrement())
  userId      String        @map("user_id")
  listingId   BigInt        @map("listing_id")
  bookingType BookingType   @map("booking_type")
  startDate   DateTime      @map("start_date") @db.Date
  endDate     DateTime      @map("end_date") @db.Date
  credits     Decimal       @db.Decimal(10, 2)
  status      BookingStatus @default(pending)
  createdAt   DateTime      @default(now()) @map("created_at")
  updatedAt   DateTime      @updatedAt @map("updated_at")

  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  listing Listing @relation(fields: [listingId], references: [id], onDelete: Cascade)

  transactions Transaction[]
  checkIns     CheckIn[]
  rating       Rating?

  @@map("bookings")
}

// New feature (not a port from the old Laravel API — no Review/Rating
// concept existed there). One rating per booking (not per listing), so a
// user booking the same listing multiple times can rate each stay
// separately. listingId is denormalized off the booking at creation time so
// average/count aggregates don't need a join through bookings. score is
// constrained to 1-5 by a CHECK constraint (see the migration), matching
// the star-rating UI already in components/RatingStars.tsx.
model Rating {
  id        BigInt   @id @default(autoincrement())
  bookingId BigInt   @unique @map("booking_id")
  userId    String   @map("user_id")
  listingId BigInt   @map("listing_id")
  score     Int
  comment   String?
  createdAt DateTime @default(now()) @map("created_at")

  booking Booking @relation(fields: [bookingId], references: [id], onDelete: Cascade)
  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  listing Listing @relation(fields: [listingId], references: [id], onDelete: Cascade)

  @@map("ratings")
}

// Activity feed row for one hooked action. Sprint 3.5 new schema item — see
// SPRINT_PLAN_NEXTJS_REWRITE.md's Sprint 3.5 "new schema items" list. No
// updatedAt: rows are append-only, never edited after insert, unlike every
// other model in this file. relatedListingId is nullable because not every
// hooked action ties to a listing (wallet_topup doesn't). No feed UI yet —
// this sprint only wires the write path; verify by querying this table
// directly after performing a hooked action.
model ActivityLog {
  id               BigInt             @id @default(autoincrement())
  userId           String             @map("user_id")
  actionType       ActivityActionType @map("action_type")
  description      String
  relatedListingId BigInt?            @map("related_listing_id")
  createdAt        DateTime           @default(now()) @map("created_at")

  user    User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  listing Listing? @relation(fields: [relatedListingId], references: [id], onDelete: SetNull)

  @@map("activity_log")
}

// Consumables-only counterpart to Booking. Unlike the old Laravel schema,
// this rewrite never supported anonymous requests (no requester_name/
// requester_email — auth was already required by the time this table was
// designed, so those legacy-only columns aren't recreated here; see
// CODEBASEAPI_SUMMARY.md §6 "Fixed during recent sprints"). `credits` is
// NOT NULL from the start (computed at creation, cost = pricePerUnit *
// quantity) — the old schema only reached NOT NULL after a backfill
// migration; this rewrite starts there directly.
model BulkOrderRequest {
  id        BigInt          @id @default(autoincrement())
  userId    String          @map("user_id")
  listingId BigInt          @map("listing_id")
  quantity  Int
  credits   Decimal         @db.Decimal(10, 2)
  status    BulkOrderStatus @default(pending)
  // Required at confirm time (2026-07-20 product owner request) — the
  // supplier's estimate of when the order will ship, shown to the buyer.
  // Nullable at the DB level only because pre-existing rows predate this
  // column; app-layer validation requires it on every confirm going forward.
  estimatedDeliveryDate DateTime? @map("estimated_delivery_date")
  // Cancellation-request pair, set together and cleared together — 2026-07-20
  // product owner request. Only meaningful while status is `confirmed`: a
  // `pending` request can be cancelled directly by the buyer (no review
  // needed, see cancelBulkOrderByUser in lib/bulk-orders.ts), but a
  // `confirmed` one has already had supplier attention, so the buyer can only
  // ask — the supplier approves (→ cancelled) or rejects (both fields
  // cleared, status stays confirmed).
  cancellationRequestedAt DateTime? @map("cancellation_requested_at")
  cancellationReason      String?   @map("cancellation_reason")
  createdAt DateTime        @default(now()) @map("created_at")
  updatedAt DateTime        @updatedAt @map("updated_at")

  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  listing Listing @relation(fields: [listingId], references: [id], onDelete: Cascade)

  transactions Transaction[]

  @@map("bulk_order_requests")
}

// "Buy Now" is deliberately NOT a BulkOrderRequest — a bulk order is a
// request the supplier still has to act on (pending/confirmed/fulfilled/
// cancelled); Buy Now is an immediate, already-completed sale: stock and
// credits move atomically at creation, there's no supplier-side status to
// transition. `stripePaymentIntentId` on Transaction is where the future
// Stripe invoice/receipt (user gets an invoice, supplier gets a receipt of
// funds — Sprint 6, not built here) will eventually hang; this model itself
// stays payment-provider-agnostic, same as every other credit-affecting
// model in this schema today.
model Purchase {
  id        BigInt   @id @default(autoincrement())
  userId    String   @map("user_id")
  listingId BigInt   @map("listing_id")
  quantity  Int
  credits   Decimal  @db.Decimal(10, 2)
  createdAt DateTime @default(now()) @map("created_at")

  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  listing Listing @relation(fields: [listingId], references: [id], onDelete: Cascade)

  transactions Transaction[]

  @@map("purchases")
}

// The wallet ledger — balance is always SUM(amount) WHERE user_id = ?, never
// stored denormalized. bookingId/bulkOrderRequestId/purchaseId nullable
// (topups aren't tied to any of them). Supports one row per credit-affecting
// event (booking create debit, booking confirm, decline/refund credit,
// bulk-order purchase, instant purchase, topup) rather than the old app's
// single create-time-only row.
model Transaction {
  id                    BigInt          @id @default(autoincrement())
  userId                String          @map("user_id")
  bookingId             BigInt?         @map("booking_id")
  bulkOrderRequestId    BigInt?         @map("bulk_order_request_id")
  purchaseId            BigInt?         @map("purchase_id")
  type                  TransactionType
  amount                Decimal         @db.Decimal(10, 2)
  stripePaymentIntentId String?         @map("stripe_payment_intent_id")
  description           String?
  createdAt             DateTime        @default(now()) @map("created_at")
  updatedAt             DateTime        @updatedAt @map("updated_at")

  user             User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  booking          Booking?          @relation(fields: [bookingId], references: [id], onDelete: SetNull)
  bulkOrderRequest BulkOrderRequest? @relation(fields: [bulkOrderRequestId], references: [id], onDelete: SetNull)
  purchase         Purchase?         @relation(fields: [purchaseId], references: [id], onDelete: SetNull)

  @@map("transactions")
}

// Sprint 3.5 new schema item. bookingId nullable — not every check-in ties to
// a booking (e.g. a supplier logging a walk-in visit), so the status side
// effect below only applies when it's set. Per the sprint plan note ("the old
// app never had a working controller for this... should decide whether
// check-in updates booking status" — confirmed with the user before building,
// see CLAUDE1.md): check-in flips a `confirmed` booking to `active`,
// check-out flips `active` to `completed` — the two enum values with no other
// writer anywhere in this codebase. Enforced in lib/check-ins.ts, not a DB
// constraint (mirrors how Booking status guards on confirm/decline are
// app-layer, not DB-layer).
model CheckIn {
  id           BigInt    @id @default(autoincrement())
  userId       String    @map("user_id")
  listingId    BigInt    @map("listing_id")
  bookingId    BigInt?   @map("booking_id")
  checkedInAt  DateTime  @default(now()) @map("checked_in_at")
  checkedOutAt DateTime? @map("checked_out_at")

  user    User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  listing Listing  @relation(fields: [listingId], references: [id], onDelete: Cascade)
  booking Booking? @relation(fields: [bookingId], references: [id], onDelete: SetNull)

  @@map("check_ins")
}

// Sprint 3.5 new schema item — backs the training session "enrolled
// participants" list referenced by the Digital Passport / training pages
// (no roster UI built yet this sprint; see SPRINT_PLAN_NEXTJS_REWRITE.md
// Sprint 3.5). One row per user per session, enforced at the DB level (not
// just app-layer) by @@unique below — same "app-layer pre-check + DB
// constraint as race-condition fallback" idiom as bookings_no_overlap (see
// lib/training-enrollments.ts and app/api/bookings/route.ts's 23P01 catch;
// this one catches Postgres 23505 instead).
model TrainingEnrollment {
  id                BigInt                   @id @default(autoincrement())
  userId            String                   @map("user_id")
  trainingSessionId BigInt                   @map("training_session_id")
  status            TrainingEnrollmentStatus @default(enrolled)
  createdAt         DateTime                 @default(now()) @map("created_at")
  updatedAt         DateTime                 @updatedAt @map("updated_at")

  user            User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  trainingSession TrainingSession @relation(fields: [trainingSessionId], references: [id], onDelete: Cascade)

  @@unique([userId, trainingSessionId])
  @@map("training_enrollments")
}

// Sprint 4, Item 4 — the tier1_video_quiz earning path: a user's graded
// submission against a TrainingVideo's quiz. Auto-graded at submission time
// (no reviewer — that's what distinguishes tier1 from the tier2a/2b
// operator/SME sign-off path, which reuses training_enrollments' existing
// status column instead of this table, per the "don't invent new statuses"
// instruction for this item). Append-only like ActivityLog/VideoCompletion —
// retries create a new row rather than overwriting, so the user's full
// attempt history is visible, not just the latest result. No unique
// constraint on (userId, trainingVideoId): retakes after a fail are allowed.
// score/totalQuestions are a snapshot of that attempt's grading, independent
// of any later edits to the quiz's question set. See lib/quiz-attempts.ts.
model QuizAttempt {
  id              BigInt   @id @default(autoincrement())
  userId          String   @map("user_id")
  trainingVideoId BigInt   @map("training_video_id")
  score           Int
  totalQuestions  Int      @map("total_questions")
  passed          Boolean
  createdAt       DateTime @default(now()) @map("created_at")

  user          User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  trainingVideo TrainingVideo @relation(fields: [trainingVideoId], references: [id], onDelete: Cascade)

  @@map("quiz_attempts")
}

// Sprint 4, Item 4 — the tier2a_operator_signoff earning path (see
// SignoffSubmissionType/SignoffRequestStatus comments above). One row per
// (userId, certificateId), not append-only like QuizAttempt: a fresh
// submission after a terminal outcome (passed/failed) updates this same row
// rather than creating a new one, per the product owner's "one record per
// user certificate" instruction. recordingKey is an R2 object key
// (lib/storage.ts), not a public URL — evidence is reviewed, not displayed —
// and is only set when submissionType is `recording`.
model CertificateSignoffRequest {
  id             BigInt                @id @default(autoincrement())
  userId         String                @map("user_id")
  certificateId  BigInt                @map("certificate_id")
  submissionType SignoffSubmissionType @map("submission_type")
  recordingKey   String?               @map("recording_key")
  status         SignoffRequestStatus  @default(pending)
  reviewedBy     String?               @map("reviewed_by")
  reviewedAt     DateTime?             @map("reviewed_at")
  createdAt      DateTime              @default(now()) @map("created_at")
  updatedAt      DateTime              @updatedAt @map("updated_at")

  user        User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  certificate Certificate @relation(fields: [certificateId], references: [id], onDelete: Cascade)
  reviewer    User?       @relation("SignoffReviewer", fields: [reviewedBy], references: [id], onDelete: SetNull)

  @@unique([userId, certificateId])
  @@map("certificate_signoff_requests")
}
