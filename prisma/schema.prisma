// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client"
  output   = "../app/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// ---------------------------------------------------------------------------
// Enums
// ---------------------------------------------------------------------------

enum UserStatus {
  active
  suspended

  @@map("user_status")
}

enum CertificateSource {
  platform
  supplier_created

  @@map("certificate_source")
}

enum CertificateStatus {
  pending
  approved
  rejected

  @@map("certificate_status")
}

// How a certificate is earned — distinct from `Certificate.category`, which
// is a different, existing classification (safety/equipment/house-rules per
// CODEBASE_SUMMARY.md). Do not conflate the two. There is no numeric
// progression between these three: each is just a different earning path,
// all producing the same kind of `user_certificates` row.
enum CertificateEarningMethod {
  tier1_video_quiz
  tier2a_operator_signoff
  tier2b_operator_or_sme_signoff

  @@map("certificate_earning_method")
}

enum ListingType {
  space
  equipment
  consumables

  @@map("listing_type")
}

enum BookingType {
  daily
  weekly
  monthly

  @@map("booking_type")
}

enum BookingStatus {
  pending
  confirmed
  active
  completed
  cancelled
  // Supplier declined this booking, a real Stripe refund is genuinely owed,
  // but which SHAPE that refund takes (cash back, or applied as a
  // BookingCredit toward a different listing) is the user's call, not
  // automatic. See declineBookingPendingResolution/resolveBookingCreditWithRefund/
  // createBookingWithDebit's bookingCreditId param (lib/bookings.ts). Never
  // set when chargeAmount was 0 (nothing to refund) — that case finalizes
  // straight to `cancelled` instead, no user decision needed.
  declined_pending_resolution

  @@map("booking_status")
}

enum BulkOrderStatus {
  pending
  confirmed
  fulfilled
  cancelled

  @@map("bulk_order_status")
}

// Scoped 2026-07-20 (product owner): confirming a bulk order places a hold on
// the buyer's credits — reserved but not yet debited, since the real debit
// still only happens at fulfillment (fulfillBulkOrderWithDebit). Deliberately
// a separate table, not a Transaction row: Transaction represents money that
// actually moved (see its own comment below), a hold is a reservation against
// money that hasn't moved yet. "Available" balance = live Transaction SUM
// minus the user's own active, non-expired holds (lib/credit-holds.ts).
enum CreditHoldStatus {
  active
  released

  @@map("credit_hold_status")
}

// topup/refund are credit-direction, booking/purchase are debit-direction —
// amount sign still carries the actual direction, this just makes the ledger
// readable instead of overloading `booking` for both the original debit and
// the decline-refund credit like the old schema did.
//
// 2026-07-20 — purchased/earned balance split (MAS Payment Services Act
// exposure fix): a single combined wallet lets purchased (SGD top-up) credit
// pay a third-party operator's booking, which this product cannot do. Two
// independent, non-interchangeable balances replace the combined one, each
// computed live off this same ledger (never stored denormalized, same
// principle as the pre-split design — see Transaction model comment below),
// just partitioned by type instead of summed as one bucket:
//   purchasedBalance = SUM(amount) WHERE type IN (purchased_topup, purchased_spend)
//   earnedBalance    = SUM(amount) WHERE type IN (earned_grant, earned_spend)
// purchased_topup/purchased_spend: bought with SGD, spendable ONLY on
//   SpaceSnap's own goods/services (consumables from SpaceSnap's own stock,
//   certification fees, gig-posting fees) — never on a booking.
// earned_grant/earned_spend: never purchased, only issued as a reward
//   (booking activity, referrals, gig-completion payouts, operator
//   promotional allocations); spendable as a discount on bookings, on
//   consumables, or a gig worker's payout choice.
// booking_payment: the real-time SGD/Stripe charge for a booking (full
//   price). Deliberately outside both balance sums above — it never touches
//   either balance directly, only records the charge for audit parity with
//   every other credit-affecting event in this ledger. An earned_spend row
//   on the same booking is what actually carries an earned-balance discount.
// The old topup/booking/refund/purchase values are kept, not removed, since
// the write paths that still use them (booking create/confirm/decline,
// bulk-order fulfillment, Buy Now) haven't been rewired to the split model
// yet — that's Sprint 3.5/6 execution work, tracked in
// SPRINT_PLAN_NEXTJS_REWRITE.md, not part of this schema change. New code
// should use the five new values below, not the old four.
//
// 2026-07-21 — consumables + gigs extension, inspected against the
// paragraph above before adding anything (per this session's own "confirm
// no duplication" instruction): earned_spend/earned_grant/purchased_spend
// were all written last session already anticipating this work —
// purchased_spend's own doc explicitly lists "gig-posting fees", and
// earned_grant/earned_spend's explicitly lists "gig-completion payouts" and
// "a gig worker's payout choice". So none of earned_spend_booking,
// earned_spend_consumable, earned_grant_gig, or gig_purchase_spend get
// added — they'd duplicate existing generic values, disambiguated instead
// by which FK is set on the row (bookingId vs purchaseId vs gigTaskId) or
// by GigAssignment.payoutChoice. The one genuinely new case: a worker
// choosing direct SGD instead of earned credit is money leaving SpaceSnap
// to a member, which nothing existing represents (booking_payment is money
// coming in) — that's the only addition below.
enum TransactionType {
  topup
  booking
  refund
  purchase

  purchased_topup
  purchased_spend
  earned_grant
  earned_spend
  booking_payment

  gig_payout_sgd

  // Sprint 4.75 addition (2026-07-21) — the 20% fee charged when a user
  // reschedules a booking 3-7 days before its (pre-modification) start date.
  // Distinct from booking_payment (the original full-price charge): reusing
  // that value would conflate "what the stay costs" with "what rescheduling
  // it cost," which is a genuinely different ledger event, same reasoning as
  // why gig_payout_sgd got its own value above instead of overloading an
  // existing one. See calculateModificationTerms, lib/booking-payments.ts,
  // and modifyBookingWithFee, lib/bookings.ts.
  booking_modification_fee

  @@map("transaction_type")
}

// Confirmed against what lib/bookings.ts, lib/bulk-orders.ts, lib/wallet.ts,
// and lib/check-ins.ts actually do this sprint, not invented ahead of the
// write-paths that populate them. One value per hooked action, not a generic
// "booking" bucket, so the eventual feed can render each row without
// re-deriving what happened from the description string.
enum ActivityActionType {
  booking_created
  booking_confirmed
  booking_declined
  booking_cancelled
  booking_modified
  bulk_order_created
  bulk_order_confirmed
  bulk_order_declined
  bulk_order_fulfilled
  bulk_order_cancelled
  bulk_order_cancellation_requested
  bulk_order_cancellation_approved
  bulk_order_cancellation_rejected
  wallet_topup
  check_in
  check_out
  training_enrolled
  quiz_attempt_submitted
  credential_issued
  signoff_requested
  signoff_reviewed
  instant_purchase_completed
  training_waitlisted
  training_waitlist_approved
  training_session_created
  booking_completed
  bulk_order_confirmed_despite_insufficient_credit

  // BookingCredit lifecycle (see lib/bookings.ts) — kept distinct from the
  // existing booking_declined/booking_cancelled above since none of those
  // describe "declined, refund deferred pending the user's own choice."
  booking_declined_pending_resolution
  booking_credit_granted
  booking_credit_redeemed
  booking_credit_refunded

  // Sprint 6.5 — User Reward Tier system (lib/reward-tiers.ts).
  reward_tier_rebate_earned
  referral_bonus_earned

  // Rewards Catalogue redemption (lib/reward-redemptions.ts) — spending
  // earnedBalance on a RewardCatalogueItem, distinct from every
  // booking/purchase-discount activity type above (those apply a RewardGrant
  // as a discount line; this is a standalone catalogue redemption).
  reward_redeemed

  // Supplier Rewards Catalogue redemption (lib/supplier-reward-redemptions.ts,
  // Sprint 6.10) — a company spending its own earned_rebate CompanyTransaction
  // balance on a SupplierRewardCatalogueItem. Distinct from reward_redeemed
  // above (that's a user spending their own personal earnedBalance).
  supplier_reward_redeemed

  @@map("activity_action_type")
}

// waitlisted (2026-07-20 product owner decision): enrollUser never rejects
// once a session is at capacity — it enrolls into this status instead. Only
// a supplier PATCH (updateEnrollmentStatus) can promote waitlisted -> enrolled;
// there is no other path back to "enrolled" (see the InvalidEnrollmentStatusTransitionError
// guard in lib/training-enrollments.ts), same as before this status existed.
enum TrainingEnrollmentStatus {
  enrolled
  waitlisted
  awaiting_signoff
  completed
  cancelled

  @@map("training_enrollment_status")
}

// Sprint 4, Item 4 — the tier2a_operator_signoff earning path. Distinct from
// TrainingEnrollmentStatus/TrainingSession: tier2a is an on-demand, per-user
// request handled directly by an operator, not a scheduled multi-participant
// session (that's tier2b, which stays on training_enrollments). Confirmed
// with the product owner after an initial build wrongly conflated the two —
// see CLAUDE1.md "Sprint 4, Item 4, Correction."
enum SignoffSubmissionType {
  recording
  live_demo_request

  @@map("signoff_submission_type")
}

// pending -> passed | live_demo_requested (recording review can only pass or
//   escalate — an operator can never hard-fail someone off a recording
//   alone, confirmed with the product owner)
// pending -> passed | failed (live_demo_request: the demo already happened,
//   so a direct pass/fail call is possible)
// live_demo_requested -> passed | failed (after the follow-up live demo)
// See lib/certificate-signoffs.ts for the enforced transition table.
enum SignoffRequestStatus {
  pending
  live_demo_requested
  passed
  failed

  @@map("signoff_request_status")
}

// 2026-07-21 — gigs, new minimal scope (confirmed via grep of this repo and
// the old Laravel codebase: neither ever had gig tables/routes before this).
// Mirrors BulkOrderStatus's shape (pending/confirmed/fulfilled/cancelled)
// but with gig-specific labels — a task is `open` until a worker is
// assigned, not "pending" (which in this schema's other enums means
// "awaiting supplier action on something already submitted").
enum GigTaskStatus {
  open
  assigned
  completed
  cancelled

  @@map("gig_task_status")
}

// The worker's choice at assignment time for how GigAssignment.payoutAmount
// gets settled at completion — see the TransactionType comment above for
// which existing ledger value each choice maps to (earned_grant vs the new
// gig_payout_sgd).
enum GigPayoutChoice {
  earned_credit
  sgd

  @@map("gig_payout_choice")
}

// 2026-07-21 write-path session — a discount request must resolve against a
// specific, server-issued grant, never a client-supplied dollar amount or a
// pooled earnedBalance sum (that pooled sum still exists for internal
// reporting, see getEarnedBalance's comment in lib/credits.ts, but nothing
// redeems against it directly as of this session). One value per reward
// flavor implied by earlier sessions' comments ("10% off your next booking",
// "1 free consumables pack", gig payout choice already schema'd via
// GigAssignment.payoutChoice) — not a general-purpose rule engine, and no
// issuance logic beyond what those three already imply (see lib/reward-grants.ts).
enum RewardGrantType {
  booking_discount_pct
  free_consumable_unit
  gig_payout_credit

  @@map("reward_grant_type")
}

enum RewardGrantStatus {
  available
  redeemed
  expired

  @@map("reward_grant_status")
}

// Merchant-of-record, direct-charge cancellation policy — which party
// cancelled a booking. Whichever party did NOT cause the cancellation is made
// whole; only the at-fault party's outcome follows the days-before-
// session-start tier (see lib/booking-payments.ts):
//   - Supplier-initiated (decline): userRefundPercent is always 100 (the user
//     didn't cause this). supplierPenaltyPercent follows the day tier
//     (0/50/100) and is applied against SpaceSnap's commission portion of the
//     booking, not the full booking value.
//   - User-initiated (cancel): userRefundPercent follows the day tier
//     (100/50/0). supplierPenaltyPercent is always 0 (the supplier didn't
//     cause this — they still get their full normal payout).
// Both fields are nullable because most bookings are never cancelled at all.
// Confirmed with the product owner 2026-07-21, correcting this session's
// earlier (unconfirmed) assumption that the day tier applied to
// userRefundPercent regardless of who cancelled — see CLAUDE1.md.
enum BookingCancelledBy {
  user
  supplier

  @@map("booking_cancelled_by")
}

// A bounded credit note issued to a user when their booking is cancelled
// under a policy that doesn't fully refund to the original Stripe charge (or
// whatever future policy decides to issue one instead of/alongside a Stripe
// refund — that resolution logic is not built this session, only the ledger
// shape it will write to). Deliberately NOT a wallet top-up: it can only ever
// be redeemed against one specific future booking, has its own expiry, and
// is never summed into purchasedBalance/earnedBalance (see
// getPurchasedBalance/getEarnedBalance, lib/credits.ts) — do not merge this
// into that balance calculation.
enum BookingCreditStatus {
  available
  applied
  // Resolved via a real Stripe refund — either the user explicitly chose
  // "refund me" (see resolveBookingCreditWithRefund, lib/bookings.ts) or the
  // 1-week forced-resolution cron swept it (sweepOverdueBookingCredits). Only
  // ever reached by a refundObligated credit — this codebase never lets real
  // owed money simply evaporate.
  refunded
  // Timed out with nothing owed on it — only reachable by a NON-obligated
  // (admin-goodwill) credit forfeiting after its 90-day window. A
  // refundObligated credit is never "expired" to nothing; see `refunded`.
  expired

  @@map("booking_credit_status")
}

model BookingCredit {
  id                 BigInt              @id @default(autoincrement())
  userId             String              @map("user_id")
  sourceBookingId    BigInt              @map("source_booking_id")
  amount             Decimal             @db.Decimal(10, 2)
  status             BookingCreditStatus @default(available)
  appliedToBookingId BigInt?             @map("applied_to_booking_id")
  // True for a supplier-decline-issued credit: this is real money the user
  // is genuinely owed, so it must resolve to either a real booking (via
  // createBookingWithDebit's bookingCreditId param) or a real Stripe refund
  // (resolveBookingCreditWithRefund) within expiresAt — never just forfeited.
  // False for an admin-granted goodwill credit (grantBookingCredit): no real
  // charge backs it, so it can simply expire unused after expiresAt with no
  // refund obligation. Drives which branch sweepOverdueBookingCredits takes
  // for a given overdue row.
  refundObligated    Boolean             @default(false) @map("refund_obligated")
  expiresAt          DateTime            @map("expires_at")
  createdAt          DateTime            @default(now()) @map("created_at")

  user             User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  sourceBooking    Booking       @relation("BookingCreditSource", fields: [sourceBookingId], references: [id], onDelete: Cascade)
  appliedToBooking Booking?      @relation("BookingCreditAppliedTo", fields: [appliedToBookingId], references: [id], onDelete: SetNull)
  transactions     Transaction[]

  @@map("booking_credits")
}

// What SpaceSnap owes a supplier, under the merchant-of-record model — the
// supplier is never paid directly by Stripe (SpaceSnap is always the
// merchant of record on the per-booking charge), so this is the ledger
// SpaceSnap's own accounts-payable process reads from to actually pay the
// supplier out, on whatever cadence their tier gets invoiced on.
//
// One row per booking (bookingId unique), but NOT one row per booking that
// exists — only for a booking that actually produced a financial event for
// the supplier ledger:
//   - Normal completion (check-out flips active -> completed): a credit row,
//     grossAmount = sgdAmount - commission, penaltyDeduction 0, netAmount =
//     grossAmount. See createCompletedBookingPayable, lib/supplier-payables.ts.
//   - Supplier-initiated decline with a non-zero cancellation-window
//     penalty: a pure DEBIT row — grossAmount 0 (the booking earned nothing,
//     the user was refunded in full), penaltyDeduction > 0, netAmount =
//     -penaltyDeduction. See declineBookingWithRefund, lib/bookings.ts.
//   - User-initiated cancel, or a supplier decline with zero penalty
//     (>=7 days out): a zero-effect audit row (all three amounts 0) — the
//     supplier is unaffected, not "still paid for a booking whose service
//     was never rendered."
// A company's actual pending payable balance is never read off a single
// row — it's the live SUM(netAmount) across all of a company's `pending`
// rows (getSupplierPendingPayableBalance, lib/supplier-payables.ts), same
// "never stored denormalized" principle as the Transaction ledger. This is
// what lets a supplier-cancellation penalty on one booking net against
// earnings from other, unrelated bookings automatically — no explicit
// "check the balance, then deduct" step is needed anywhere; the SUM already
// reflects it, and can go negative (supplier owes SpaceSnap back) if
// penalties exceed pending earnings.
// Renamed 2026-07-23 from "invoiced" to "scheduled" — this ledger tracks
// what SpaceSnap owes a supplier (a payout SpaceSnap issues), not something
// the supplier invoices SpaceSnap for; "invoiced" had it backwards. Not yet
// set by any real code path (no payout-run job exists yet — see the open
// Sprint 6 Invoice/Receipt gap), same as before the rename.
enum SupplierPayableStatus {
  pending
  scheduled
  paid

  @@map("supplier_payable_status")
}

// Snapshot of the company's supplier tier payout cadence AT THE TIME this
// payable was created — deliberately not a live join, so a mid-cycle tier
// change never reaches back and reshuffles a payable that's already
// pending/scheduled. The tier itself is never stored (lib/supplier-tiers.ts
// computes it live from bookings/cancellation-rate/spend, Sprint 6.10) —
// this column just holds the cadence that tier mapped to at creation time.
// Renamed 2026-07-23 from InvoicingCadence — this is SpaceSnap paying OUT to
// the supplier, not the supplier invoicing SpaceSnap; "invoicing" had the
// direction of money flow backwards. Every tier maps to biweekly as of the
// same rename (see SUPPLIER_TIER_PAYOUT_CADENCE, lib/booking-payments.ts) —
// monthly/weekly stay in the enum only because pre-existing SupplierPayable
// rows may have snapshotted them before that change.
enum PayoutCadence {
  monthly
  biweekly
  weekly

  @@map("payout_cadence")
}

model SupplierPayable {
  id               BigInt                @id @default(autoincrement())
  companyId        BigInt                @map("company_id")
  bookingId        BigInt                @unique @map("booking_id")
  grossAmount      Decimal               @map("gross_amount") @db.Decimal(10, 2)
  penaltyDeduction Decimal               @default(0) @map("penalty_deduction") @db.Decimal(10, 2)
  netAmount        Decimal               @map("net_amount") @db.Decimal(10, 2)
  status           SupplierPayableStatus @default(pending)
  payoutCadence    PayoutCadence         @map("payout_cadence")
  createdAt        DateTime              @default(now()) @map("created_at")

  company Company @relation(fields: [companyId], references: [id], onDelete: Cascade)
  booking Booking @relation(fields: [bookingId], references: [id], onDelete: Cascade)

  @@map("supplier_payables")
}

// A per-COMPANY credit ledger, distinct from the per-USER purchased/earned
// split (Transaction, lib/credits.ts) — same "live SUM, never denormalized"
// idiom, same purchased/earned split, but never merged into the User
// ledger: a company's own balance and an individual member's personal
// wallet are unrelated concepts, same reasoning as why BuyerOrganization
// (still just a planning thread as of this migration) would need its own
// separate pooled ledger rather than reusing this one.
//
// Confirmed with the product owner 2026-07-22 (Sprint 6.10 Supplier
// Financials "Purchased/Earned Credits cards" item): a REAL balance now,
// but no spend flow yet — nothing redeems against `earned_rebate` here
// today (the still-open Supplier Rewards Catalogue thread is the likely
// future spender, once that catalogue's own per-category design is
// settled; not guessed at here).
enum CompanyTransactionType {
  // A company member topping up the shared company wallet — confirmed: any
  // member can do this, no isCompanyAdmin-only gate (mirrors the "no
  // separate purchaser role" decision already made for the BuyerOrganization
  // thread). Credits-only for now, same as the per-user wallet top-up
  // (lib/wallet.ts) — no real Stripe charge backs this yet.
  purchased_topup
  // Automatic rebate paid out when one of the company's own bookings
  // completes (checkOutCheckIn, lib/check-ins.ts) — confirmed: same shape
  // as the user reward tier's completion-time rebate (lib/reward-tiers.ts),
  // sized off the company's own live-computed supplier tier
  // (lib/supplier-tiers.ts). The exact per-tier percentages are this
  // session's own inference, not confirmed with the product owner — see
  // COMPANY_REBATE_PERCENT's own comment in lib/company-credits.ts.
  earned_rebate
  // A company spending its own earned_rebate balance on a
  // SupplierRewardCatalogueItem (lib/supplier-reward-redemptions.ts, Sprint
  // 6.10 — the spender this type's own comment above already anticipated).
  // Negative amount, same sign convention as the per-user earned_spend
  // Transaction type.
  earned_spend
  // Sprint 6.12 — a company spending its own purchasedBalance on Bumps or a
  // Pin (lib/company-credits.ts's purchaseBumps, lib/listings.ts's
  // purchaseAndApplyPin). Negative amount, mirrors the per-user
  // TransactionType.purchased_spend convention exactly (see
  // lib/purchases.ts's `chargeAmount.negated()`). Missing from this enum
  // until now — getCompanyPurchasedBalance only ever summed purchased_topup,
  // since nothing previously spent the company's purchased balance; the
  // per-user equivalent already included purchased_spend in its own sum.
  purchased_spend

  @@map("company_transaction_type")
}

model CompanyTransaction {
  id                         BigInt                 @id @default(autoincrement())
  companyId                  BigInt                 @map("company_id")
  // Who triggered a purchased_topup — null for an earned_rebate row, which
  // isn't any one member's action (it's paid out automatically on booking
  // completion).
  userId                     String?                @map("user_id")
  // Set only on an earned_rebate row — ties it back to the booking that
  // earned it, same "trace the ledger row back to what authorized it"
  // pattern as Transaction.rewardGrantId/bookingCreditId.
  bookingId                  BigInt?                @map("booking_id")
  // Set only on an earned_spend row — ties it back to the Supplier Rewards
  // Catalogue redemption that debited it.
  supplierRewardRedemptionId BigInt?                @map("supplier_reward_redemption_id")
  type                       CompanyTransactionType
  amount                     Decimal                @db.Decimal(10, 2)
  description                String?
  createdAt                  DateTime               @default(now()) @map("created_at")

  company                  Company                   @relation(fields: [companyId], references: [id], onDelete: Cascade)
  user                     User?                     @relation(fields: [userId], references: [id], onDelete: SetNull)
  booking                  Booking?                  @relation(fields: [bookingId], references: [id], onDelete: SetNull)
  supplierRewardRedemption SupplierRewardRedemption? @relation(fields: [supplierRewardRedemptionId], references: [id], onDelete: SetNull)

  @@index([companyId])
  @@map("company_transactions")
}

// A grant is issued with its own resolved type+value (e.g. `booking_discount_pct`
// value 10 = 10% off) and can only ever be redeemed once, atomically with the
// booking/purchase it discounts — see redeemRewardGrant (lib/reward-grants.ts),
// which flips status via an updateMany WHERE status:'available' guard so a
// race between two concurrent redemption attempts can't double-spend the same
// grant. grantedVia is a loose free-text label (e.g. "booking", "referral",
// "gig"), not an FK — no issuing flow exists yet for any of these, so there's
// nothing concrete to reference back to.
model RewardGrant {
  id         BigInt            @id @default(autoincrement())
  userId     String            @map("user_id")
  type       RewardGrantType
  value      Decimal           @db.Decimal(10, 2)
  status     RewardGrantStatus @default(available)
  grantedVia String            @map("granted_via")
  redeemedAt DateTime?         @map("redeemed_at")
  // Nullable — only grants issued with a real deadline set this (e.g. a
  // Discount Voucher redeemed from the rewards catalogue, 90 days per
  // lib/reward-redemptions.ts's DISCOUNT_VOUCHER_GRANT_EXPIRY_DAYS). A grant
  // with no expiresAt never expires, preserving every pre-2026-07-22 grant's
  // behavior (seeded/created directly, no issuance flow existed before this).
  // Lazily enforced at read/redeem time (resolveRewardGrantDiscount, the new
  // GET /api/rewards/grants) — same "lazy expiry on read" idiom as
  // CreditHold/BookingCredit, not a scheduled job.
  expiresAt  DateTime?         @map("expires_at")
  createdAt  DateTime          @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  transactions Transaction[]

  @@index([userId, status])
  @@map("reward_grants")
}

// The redemption *catalogue* shown in RewardsCatalogueModal (Sprint 6.6) —
// distinct from RewardGrant above, which represents an issued/redeemed
// grant, not a catalogue definition. Sprint 6.9: this is an open-ended list
// (admin can add/delete items, not a fixed set of 7) — identity is just
// `id`; `category` fixes which of the fields below are meaningful for a
// given row (enforced in the admin API, not a DB constraint). Every field
// below other than the shared id/category/name/description/active columns
// is nullable and only ever set for its own category — see each field's own
// comment.
enum RewardCatalogueCategory {
  discount
  pitch_ticket
  consultancy
  events
  lucky_draw
  tier_upgrade
  consumable

  @@map("reward_catalogue_category")
}

// certification_fee was removed 2026-07-22 (Sprint 6.10 fulfillment session,
// confirmed with the product owner) — no certification/credential in this
// codebase ever charges a fee (confirmed by grep), so the option had nothing
// to discount against. Re-add if a real cert-fee feature ever ships.
enum RewardDiscountAppliesTo {
  booking
  equipment

  @@map("reward_discount_applies_to")
}

model RewardCatalogueItem {
  id          BigInt                  @id @default(autoincrement())
  category    RewardCatalogueCategory
  name        String
  description String
  active      Boolean                 @default(true)

  // Universal to every category (2026-07-22 addition, caught late by the
  // product owner after the initial per-category fields shipped) — how many
  // earned credits a redemption of this item costs.
  creditCost        Decimal @default(0) @map("credit_cost") @db.Decimal(10, 2)
  // Total redemptions admin is willing to give out, null = unlimited. Once
  // redeemedCount reaches this, the item is "Fully Redeemed" (see
  // isFullyRedeemed, lib/reward-catalogue.ts) and should stop being
  // redeemable — display-only for now: no redemption flow exists anywhere
  // in this codebase yet (see Sprint 6.6/6.7's own notes), so this can
  // never actually increment yet. Building the capacity fields ahead of
  // that flow, same as this catalogue's other schema-before-wiring gaps.
  quantityAvailable Int?    @map("quantity_available")
  // Never client-settable (no admin PATCH field for this) — only a real
  // future redemption endpoint should ever increment it.
  redeemedCount     Int     @default(0) @map("redeemed_count")

  // category: discount
  discountPercent   Decimal?                  @map("discount_percent") @db.Decimal(5, 2)
  discountAppliesTo RewardDiscountAppliesTo[] @default([]) @map("discount_applies_to")

  // category: pitch_ticket + consultancy share this ("which partners can the
  // user pick from"). Replaced 2026-07-22 (confirmed with the product owner)
  // from a single partnerName to a list — a user picks their preferred
  // partner at redemption time (RewardRedemption.selectedPartnerOption), one
  // admin-managed catalogue item can now offer several partners instead of
  // needing a separate item per partner.
  partnerOptions     String[] @default([]) @map("partner_options")
  // category: consultancy only — free text, not a dropdown; subject varies
  // too much to enumerate ("Legal? Accounting? HR?")
  consultancySubject String?  @map("consultancy_subject")

  // category: events
  eventName String? @map("event_name")
  eventInfo String? @map("event_info")

  // category: lucky_draw
  prizeDescription String? @map("prize_description")
  prizeQuantity    Int?    @map("prize_quantity")

  // category: tier_upgrade
  upgradeDurationMonths Int? @map("upgrade_duration_months")

  // category: consumable
  consumableName     String? @map("consumable_name")
  consumableQuantity Int?    @map("consumable_quantity")

  updatedAt DateTime @updatedAt @map("updated_at")
  createdAt DateTime @default(now()) @map("created_at")

  redemptions RewardRedemption[]

  @@map("reward_catalogue_items")
}

// Fulfillment status for a RewardRedemption (2026-07-22 fulfillment session,
// confirmed with the product owner — see SPRINT_PLAN_NEXTJS_REWRITE.md
// Sprint 6.10 "per-category redemption/fulfillment design"). Most categories
// are done the instant they're redeemed (discount, consumable, tier_upgrade
// — the effect fires immediately, there's nothing left to resolve) and are
// created directly as `used`. pitch_ticket/consultancy are the only
// categories that start `pending`: the admin needs to arrange scheduling
// with the user's chosen partner out-of-band, then come back and mark the
// case `used` (arranged) or `cancelled` (fell through, e.g. unreachable).
enum RewardRedemptionStatus {
  pending
  used
  cancelled

  @@map("reward_redemption_status")
}

// A user spending earnedBalance on a RewardCatalogueItem — the actual
// issuance/redemption flow that item's own `redeemedCount` field was added
// ahead of (see that field's comment above). Distinct from RewardGrant: that
// model is a server-issued discount applied to a specific booking/purchase
// charge; this is a standalone catalogue redemption with no booking/purchase
// involved, debited straight from earnedBalance via an earned_spend
// Transaction.
//
// itemName/itemCategory/creditCost are snapshotted at redemption time, same
// principle as Booking.platformCommissionPercent/rewardTierRebatePercent
// elsewhere in this schema — an admin editing or hard-deleting the catalogue
// item afterward (Sprint 6.9's DELETE route) must never reshuffle or blank
// out what the user actually redeemed. rewardCatalogueItemId is therefore
// nullable/SetNull, not the source of truth for display.
model RewardRedemption {
  id                    BigInt                  @id @default(autoincrement())
  userId                String                  @map("user_id")
  rewardCatalogueItemId BigInt?                 @map("reward_catalogue_item_id")
  itemName              String                  @map("item_name")
  itemCategory          RewardCatalogueCategory @map("item_category")
  creditCost            Decimal                 @map("credit_cost") @db.Decimal(10, 2)
  status                RewardRedemptionStatus  @default(used)
  // category: pitch_ticket + consultancy only — which of the item's
  // partnerOptions the user picked at redemption time. Snapshotted (not a
  // live lookup into the item's own list) for the same reason
  // itemName/itemCategory are — an admin later editing the item's partner
  // list must never reshuffle what a user already selected.
  selectedPartnerOption String?                 @map("selected_partner_option")
  // category: tier_upgrade only — createdAt + the item's upgradeDurationMonths
  // AT REDEMPTION TIME, resolved and stored once (same "snapshot, don't
  // recompute against a possibly-deleted item" discipline as creditCost/
  // itemName above). Also doubles as the "is an upgrade currently active"
  // check (lib/reward-redemptions.ts rejects a second tier_upgrade
  // redemption while one's expiresAt is still in the future) and as the
  // window lib/reward-tiers.ts's getUserRewardTier reads to decide whether
  // to apply the one-tier boost.
  expiresAt             DateTime?               @map("expires_at")
  createdAt             DateTime                @default(now()) @map("created_at")

  user                User                 @relation(fields: [userId], references: [id], onDelete: Cascade)
  rewardCatalogueItem RewardCatalogueItem? @relation(fields: [rewardCatalogueItemId], references: [id], onDelete: SetNull)
  transactions        Transaction[]

  @@index([userId])
  @@map("reward_redemptions")
}

// Category for the SUPPLIER-facing (company) rewards catalogue — deliberately
// a separate model tree from RewardCatalogueCategory above, not an extension
// of it: report/ad/system share zero fields with discount/pitch_ticket/.../
// consumable, and redemption here debits a Company's own earned_rebate
// CompanyTransaction balance, not any individual user's earnedBalance. See
// SPRINT_PLAN_NEXTJS_REWRITE.md Sprint 6.10 "Supplier Rewards Catalogue" for
// the full design history.
enum SupplierRewardCategory {
  report
  ad
  system

  @@map("supplier_reward_category")
}

// category: report, "Targeted Insights Report" only — which slice of the
// company's own data the report covers, multi-select. "Platform Performance
// Report" (the other seeded report item) has no extra fields, an empty array
// here.
enum SupplierReportTargetGroup {
  bookings
  equipment
  consumables

  @@map("supplier_report_target_group")
}

// report/ad redemptions have no automation behind them — no report-generation
// engine, no ad-serving system exists anywhere in this codebase — so they
// start pending and an admin fulfils the request out-of-band, then marks it
// used/cancelled. Mirrors RewardRedemptionStatus's pitch_ticket/consultancy
// precedent exactly. system (Tier Boost) redemptions resolve instantly, same
// as tier_upgrade on the user-facing catalogue.
enum SupplierRewardRedemptionStatus {
  pending
  used
  cancelled

  @@map("supplier_reward_redemption_status")
}

model SupplierRewardCatalogueItem {
  id          BigInt                 @id @default(autoincrement())
  category    SupplierRewardCategory
  name        String
  description String
  active      Boolean                @default(true)

  creditCost        Decimal @default(0) @map("credit_cost") @db.Decimal(10, 2)
  quantityAvailable Int?    @map("quantity_available")
  redeemedCount     Int     @default(0) @map("redeemed_count")

  // category: report ("Targeted Insights Report" only)
  reportTargetGroups SupplierReportTargetGroup[] @default([]) @map("report_target_groups")

  // category: ad — length of the campaign/placement window in days, replaces
  // the old hardcoded "week-long"/"priority placement" static copy the
  // placeholder UI shipped with.
  campaignDurationDays Int? @map("campaign_duration_days")

  // category: system (Tier Boost) — same shape/semantics as
  // RewardCatalogueItem.upgradeDurationMonths above.
  upgradeDurationMonths Int? @map("upgrade_duration_months")

  updatedAt DateTime @updatedAt @map("updated_at")
  createdAt DateTime @default(now()) @map("created_at")

  redemptions SupplierRewardRedemption[]

  @@map("supplier_reward_catalogue_items")
}

// A company spending its own earned_rebate CompanyTransaction balance on a
// SupplierRewardCatalogueItem — the company-scoped mirror of RewardRedemption.
// redeemedByUserId records which member actually clicked redeem (display/
// audit only — the balance and the item belong to the company, not that
// member personally). itemName/itemCategory/creditCost snapshotted at
// redemption time, same reasoning as RewardRedemption's own fields.
model SupplierRewardRedemption {
  id                            BigInt                         @id @default(autoincrement())
  companyId                     BigInt                         @map("company_id")
  redeemedByUserId              String                         @map("redeemed_by_user_id")
  supplierRewardCatalogueItemId BigInt?                        @map("supplier_reward_catalogue_item_id")
  itemName                      String                         @map("item_name")
  itemCategory                  SupplierRewardCategory         @map("item_category")
  creditCost                    Decimal                        @map("credit_cost") @db.Decimal(10, 2)
  status                        SupplierRewardRedemptionStatus @default(used)
  // category: system (Tier Boost) only — createdAt + the item's
  // upgradeDurationMonths AT REDEMPTION TIME, resolved and stored once.
  // Doubles as the "is a boost currently active" check
  // (lib/supplier-reward-redemptions.ts rejects a second system redemption
  // while one's expiresAt is still in the future) and as what
  // lib/supplier-tiers.ts reads to decide whether to bump the displayed
  // tier — same dual role as RewardRedemption.expiresAt for tier_upgrade.
  expiresAt                     DateTime?                      @map("expires_at")
  createdAt                     DateTime                       @default(now()) @map("created_at")

  company                     Company                      @relation(fields: [companyId], references: [id], onDelete: Cascade)
  redeemedByUser              User                         @relation(fields: [redeemedByUserId], references: [id], onDelete: Cascade)
  supplierRewardCatalogueItem SupplierRewardCatalogueItem? @relation(fields: [supplierRewardCatalogueItemId], references: [id], onDelete: SetNull)
  companyTransactions         CompanyTransaction[]

  @@index([companyId])
  @@map("supplier_reward_redemptions")
}

// ---------------------------------------------------------------------------
// Auth.js (NextAuth v5) — required by @auth/prisma-adapter, session strategy
// "database" per auth.ts. Model names must stay User/Account/Session/
// VerificationToken so the adapter's p.user/p.account/... calls resolve.
// ---------------------------------------------------------------------------

model Account {
  id                String  @id @default(cuid())
  userId            String  @map("user_id")
  type              String
  provider          String
  providerAccountId String  @map("provider_account_id")
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@map("accounts")
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique @map("session_token")
  userId       String   @map("user_id")
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("sessions")
}

model VerificationToken {
  identifier String
  token      String
  expires    DateTime

  @@unique([identifier, token])
  @@map("verification_tokens")
}

// ---------------------------------------------------------------------------
// Domain
// ---------------------------------------------------------------------------

model Company {
  id                   BigInt   @id @default(autoincrement())
  name                 String
  businessName         String?  @map("business_name")
  businessDescription  String?  @map("business_description")
  contactEmail         String?  @map("contact_email")
  businessLocation     String?  @map("business_location")
  yearsOperating       Int?     @map("years_operating")
  // Added for the supplier profile "Business Details" edit form — the
  // registration number and finance contact fields the old CODEBASE_SUMMARY.md
  // gap note said had no backing columns at all (distinct from contactEmail,
  // which is the company's general contact address, not accounts/finance).
  registrationNumber   String?  @map("registration_number")
  financeContactEmail  String?  @map("finance_contact_email")
  financeContactPerson String?  @map("finance_contact_person")
  // Sprint 6.12 — "ammo" a company holds, purchased in quantity
  // (purchaseBumps, lib/company-credits.ts) and spent one at a time
  // (activateBump, lib/listings.ts, resets a listing's boostedAt to now()).
  // A plain counter, not derived from a ledger — unlike credit balances,
  // there's no independent source of truth to re-derive this from (a spent
  // Bump doesn't leave its own row anywhere else to re-sum).
  bumpsAvailable       Int      @default(0) @map("bumps_available")
  // Supplier payment tier (free/preferred/top) is deliberately NOT a column
  // here — it's live-computed from rating + rolling-window spend
  // (lib/supplier-tiers.ts, Sprint 6.10, confirmed with the product owner
  // 2026-07-22). It was a manual admin-set column/route until this session;
  // both were removed rather than left to fight the automatic calculation
  // (migration `20260722_remove_supplier_tier_column`).
  createdAt            DateTime @default(now()) @map("created_at")
  updatedAt            DateTime @updatedAt @map("updated_at")

  users                     User[]
  listings                  Listing[]
  certificates              Certificate[]
  trainingVideos            TrainingVideo[]
  trainingSessions          TrainingSession[]
  supplierPayables          SupplierPayable[]
  companyTransactions       CompanyTransaction[]
  supplierRewardRedemptions SupplierRewardRedemption[]
  joinRequests              CompanyJoinRequest[]
  supplierEdmCampaign       SupplierEdmCampaign?

  @@map("companies")
}

enum JoinRequestStatus {
  pending
  approved
  rejected
}

// Sprint 6.10 follow-on (2026-07-23) — company-side membership management.
// A user "joining" a company (found via search-or-create at signup, or later
// from the supplier profile) is seated immediately if the company has no
// admin yet (nothing to gate against), or queued here until the company's
// own admin approves/rejects it (lib/company-membership.ts). No DB-level
// uniqueness on (companyId, requestedByUserId) scoped to "pending" only —
// Prisma can't express a partial unique index natively; the app layer
// already blocks a second pending request for the same pair.
model CompanyJoinRequest {
  id                BigInt            @id @default(autoincrement())
  companyId         BigInt            @map("company_id")
  requestedByUserId String            @map("requested_by_user_id")
  status            JoinRequestStatus @default(pending)
  resolvedByUserId  String?           @map("resolved_by_user_id")
  resolvedAt        DateTime?         @map("resolved_at")
  createdAt         DateTime          @default(now()) @map("created_at")

  company     Company @relation(fields: [companyId], references: [id], onDelete: Cascade)
  requestedBy User    @relation("CompanyJoinRequestRequester", fields: [requestedByUserId], references: [id], onDelete: Cascade)
  resolvedBy  User?   @relation("CompanyJoinRequestResolver", fields: [resolvedByUserId], references: [id], onDelete: SetNull)

  @@index([companyId, status])
  @@map("company_join_requests")
}

// Buyer-side counterpart to Company — a corporate customer account for a
// group of members who share a purchased-credit pool (Sprint 6.10 "User-Side
// Buyer Organization" design thread, 2026-07-23). Deliberately a separate
// model from Company, not a reuse — Company is always a seller (lists
// spaces/equipment/consumables, has certificates/training/payables); this is
// always a buyer, with none of that. Only the purchased-credit pool is ever
// shared between members — earnedBalance, reward tier, and referrals all
// stay strictly individual (confirmed with the product owner, untouched by
// this model). The actual pooled-spend write path (a booking/purchase
// funded from this org rather than the member's own purchasedBalance) is
// deliberately not built yet — Transaction.buyerOrganizationId below is
// schema-only groundwork, same "schema now, write path later" convention as
// the gig tables.
model BuyerOrganization {
  id                   BigInt   @id @default(autoincrement())
  name                 String
  registrationNumber   String?  @map("registration_number")
  financeContactEmail  String?  @map("finance_contact_email")
  financeContactPerson String?  @map("finance_contact_person")
  createdAt            DateTime @default(now()) @map("created_at")
  updatedAt            DateTime @updatedAt @map("updated_at")

  users        User[]
  joinRequests BuyerOrganizationJoinRequest[]
  transactions Transaction[]

  @@map("buyer_organizations")
}

// Mirrors CompanyJoinRequest exactly, scoped to BuyerOrganization instead —
// same "no admin yet = seat immediately, admin exists = queue for their
// approval" state machine (lib/buyer-organizations.ts).
model BuyerOrganizationJoinRequest {
  id                  BigInt            @id @default(autoincrement())
  buyerOrganizationId BigInt            @map("buyer_organization_id")
  requestedByUserId   String            @map("requested_by_user_id")
  status              JoinRequestStatus @default(pending)
  resolvedByUserId    String?           @map("resolved_by_user_id")
  resolvedAt          DateTime?         @map("resolved_at")
  createdAt           DateTime          @default(now()) @map("created_at")

  buyerOrganization BuyerOrganization @relation(fields: [buyerOrganizationId], references: [id], onDelete: Cascade)
  requestedBy       User              @relation("BuyerOrgJoinRequestRequester", fields: [requestedByUserId], references: [id], onDelete: Cascade)
  resolvedBy        User?             @relation("BuyerOrgJoinRequestResolver", fields: [resolvedByUserId], references: [id], onDelete: SetNull)

  @@index([buyerOrganizationId, status])
  @@map("buyer_organization_join_requests")
}

// Role is derived from the three booleans, never a single enum column —
// carried over deliberately from the old schema (see AGENTS/CODEBASEAPI_SUMMARY §6).
// is_verified is intentionally NOT included: it was a half-built admin-review
// concept in the old app with no defined trigger or enforcement.
// Capabilities are additive (company admin implies supplier), enforced by the
// `users_company_admin_requires_supplier` CHECK constraint added in migration
// 20260718192008_users_company_admin_requires_supplier (raw SQL — Prisma
// can't express cross-column CHECK constraints natively). isBuyerOrgAdmin
// mirrors that same additive pattern (requires buyerOrganizationId), enforced
// by the sibling `users_buyer_org_admin_requires_org` CHECK constraint added
// in migration 20260723000000_buyer_organizations.
model User {
  id                         String     @id @default(cuid())
  name                       String
  email                      String     @unique
  emailVerified              DateTime?  @map("email_verified")
  password                   String
  title                      String?
  avatarUrl                  String?    @map("avatar_url")
  isSupplier                 Boolean    @default(false) @map("is_supplier")
  // 2026-07-23 — signup's Member/Supplier/Both role choice is now
  // exclusive/enforced (proxy.ts, RoleGuard.tsx), not just additive: a
  // "Supplier" role account can no longer reach the user-side routes
  // (marketplace/passport/wallet/dashboard) at all, only "Member"/"Both"
  // can. isSupplier alone can't express this (it's identical for
  // "Supplier" and "Both"), so this is a genuinely separate signal, not
  // derived from isSupplier. Defaults true so every pre-existing row
  // (seed.ts, any account created before this field existed) keeps its
  // current behavior — the exclusivity only applies going forward, driven
  // by app/api/auth/register/route.ts's own role handling.
  isMember                   Boolean    @default(true) @map("is_member")
  isCompanyAdmin             Boolean    @default(false) @map("is_company_admin")
  isSystemAdmin              Boolean    @default(false) @map("is_system_admin")
  companyId                  BigInt?    @map("company_id")
  promotionRequested         Boolean    @default(false) @map("promotion_requested")
  // Sprint 6.10 follow-on (2026-07-23) — Buyer Organization membership,
  // mirrors companyId/isCompanyAdmin/promotionRequested exactly but for the
  // buyer-side BuyerOrganization model instead of the supplier-side Company.
  // A member's promotion-to-admin only ever reaches SpaceSnap's system admin
  // when their org currently has no admin at all — once an org has an admin,
  // that admin promotes/removes members directly (lib/buyer-organizations.ts),
  // same rule this session applied to the existing Company promotion flow
  // (lib/promotions.ts).
  buyerOrganizationId        BigInt?    @map("buyer_organization_id")
  isBuyerOrgAdmin            Boolean    @default(false) @map("is_buyer_org_admin")
  buyerOrgPromotionRequested Boolean    @default(false) @map("buyer_org_promotion_requested")
  stripeCustomerId           String?    @map("stripe_customer_id")
  stripeConnectAccountId     String?    @map("stripe_connect_account_id")
  status                     UserStatus @default(active)
  // Sprint 6.5 addition (2026-07-21) — User Reward Tier referral mechanic.
  // referralCode is THIS user's own shareable code, generated in
  // application code at registration (app/api/auth/register/route.ts) —
  // existing rows backfilled via raw SQL in the migration (Postgres has no
  // clean column-default expression for a friendly random string, same
  // "Prisma/DB can't express this, so raw SQL" precedent as the bookings
  // exclusion constraint). referredByUserId is set once, at signup, if a
  // valid code was supplied. referralConvertedAt is set once THIS user's
  // own referral has produced a qualifying booking and the referrer was
  // paid (maybeConvertReferral, lib/reward-tiers.ts) — guards against
  // paying the same referral twice; a repeat qualifying booking by this
  // same user is a no-op once this is set.
  // DB-generated default so every OTHER prisma.user.create call in this
  // codebase (seed.ts, every lib/*.test.ts fixture) doesn't need to know
  // about this Sprint 6.5 field at all — only app/api/auth/register/route.ts
  // explicitly generates+sets one (its own collision-retry loop).
  referralCode               String     @unique @default(dbgenerated("substr(md5(random()::text || clock_timestamp()::text), 1, 8)")) @map("referral_code")
  referredByUserId           String?    @map("referred_by_user_id")
  referralConvertedAt        DateTime?  @map("referral_converted_at")
  // Sprint 6.12 addition (2026-07-23) — real request-level activity
  // tracking, stamped in auth.ts's jwt callback on every authenticated
  // request (both the first-sign-in branch and the existing per-request DB
  // re-check, which already ran a query here regardless). Not exposed on
  // the session/JWT — nothing needs synchronous frontend access to it, it's
  // only ever read back via its own dedicated API call (see
  // lastEdmSeenAt/the EDM popup trigger below).
  lastActivityAt             DateTime?  @map("last_activity_at")
  // Stamped by dismissEdmCampaign (lib/edm-campaigns.ts) whenever the EDM
  // sign-in popup is shown/dismissed. The popup re-fires once this is null
  // or at least 6 hours old — see getActiveEdmForUser's own comment for the
  // deliberately simplified trigger condition (checked once per layout
  // mount, not polled).
  lastEdmSeenAt              DateTime?  @map("last_edm_seen_at")
  createdAt                  DateTime   @default(now()) @map("created_at")
  updatedAt                  DateTime   @updatedAt @map("updated_at")

  company           Company?           @relation(fields: [companyId], references: [id], onDelete: SetNull)
  buyerOrganization BuyerOrganization? @relation(fields: [buyerOrganizationId], references: [id], onDelete: SetNull)
  referredBy        User?              @relation("UserReferrals", fields: [referredByUserId], references: [id], onDelete: SetNull)
  referredUsers     User[]             @relation("UserReferrals")

  companyJoinRequestsMade      CompanyJoinRequest[]           @relation("CompanyJoinRequestRequester")
  companyJoinRequestsResolved  CompanyJoinRequest[]           @relation("CompanyJoinRequestResolver")
  buyerOrgJoinRequestsMade     BuyerOrganizationJoinRequest[] @relation("BuyerOrgJoinRequestRequester")
  buyerOrgJoinRequestsResolved BuyerOrganizationJoinRequest[] @relation("BuyerOrgJoinRequestResolver")

  accounts Account[]
  sessions Session[]

  reviewedCertificates      Certificate[]               @relation("CertificateReviewer")
  userCertificates          UserCertificate[]
  signoffRequests           CertificateSignoffRequest[]
  reviewedSignoffRequests   CertificateSignoffRequest[] @relation("SignoffReviewer")
  videoCompletions          VideoCompletion[]
  bookings                  Booking[]
  bulkOrderRequests         BulkOrderRequest[]
  purchases                 Purchase[]
  transactions              Transaction[]
  checkIns                  CheckIn[]
  activityLogs              ActivityLog[]
  trainingEnrollments       TrainingEnrollment[]
  ratings                   Rating[]
  quizAttempts              QuizAttempt[]
  creditHolds               CreditHold[]
  postedGigTasks            GigTask[]                   @relation("GigTaskPoster")
  gigAssignments            GigAssignment[]             @relation("GigAssignmentWorker")
  rewardGrants              RewardGrant[]
  bookingCredits            BookingCredit[]
  notifications             Notification[]
  referralSpendBonuses      ReferralSpendBonus[]
  rewardRedemptions         RewardRedemption[]
  companyTransactions       CompanyTransaction[]
  supplierRewardRedemptions SupplierRewardRedemption[]
  announcementsCreated      Announcement[]              @relation("AnnouncementCreatedBy")
  announcementReads         AnnouncementRead[]
  bannersUpdated            Banner[]                    @relation("BannerUpdatedBy")
  adminEdmCampaignsCreated  AdminEdmCampaign[]          @relation("AdminEdmCampaignCreatedBy")
  supplierEdmCampaignsMade  SupplierEdmCampaign[]       @relation("SupplierEdmCampaignCreatedBy")

  @@map("users")
}

// Sprint 6.5 — User Reward Tier referral mechanic. A phantom bump added to
// the referrer's rolling-window "spend" figure for tier-qualification math
// only (getUserRewardTierWindowStats, lib/reward-tiers.ts) — deliberately
// NOT a Transaction (would incorrectly inflate purchasedBalance/
// earnedBalance, see TransactionType's comment above) and NOT merged into
// BookingCredit (different lifecycle/purpose: that's a real, redeemable
// credit note, this is just an input to a threshold comparison). The
// referrer's actual reward (a real earned_grant Transaction) is separate —
// see maybeConvertReferral, lib/reward-tiers.ts.
model ReferralSpendBonus {
  id        BigInt   @id @default(autoincrement())
  userId    String   @map("user_id")
  amount    Decimal  @default(200) @db.Decimal(10, 2)
  createdAt DateTime @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("referral_spend_bonuses")
}

// App-layer rule (not DB-enforced yet): only status=approved certs may be
// referenced by listing_required_certificates or user_certificates.
model Certificate {
  id                 BigInt                   @id @default(autoincrement())
  name               String
  icon               String?
  category           String?
  earningMethod      CertificateEarningMethod @default(tier1_video_quiz) @map("earning_method")
  submissionNotes    String?                  @map("submission_notes")
  source             CertificateSource        @default(platform)
  status             CertificateStatus        @default(approved)
  createdByCompanyId BigInt?                  @map("created_by_company_id")
  reviewedBy         String?                  @map("reviewed_by")
  reviewedAt         DateTime?                @map("reviewed_at")
  createdAt          DateTime                 @default(now()) @map("created_at")
  updatedAt          DateTime                 @updatedAt @map("updated_at")

  createdByCompany Company? @relation(fields: [createdByCompanyId], references: [id], onDelete: SetNull)
  reviewer         User?    @relation("CertificateReviewer", fields: [reviewedBy], references: [id], onDelete: SetNull)

  requiredForListings ListingRequiredCertificate[]
  userCertificates    UserCertificate[]
  trainingVideos      TrainingVideo[]
  trainingSessions    TrainingSession[]
  signoffRequests     CertificateSignoffRequest[]
  notifications       Notification[]

  @@map("certificates")
}

// Pricing fields are nullable here because the day/week/month vs.
// per_unit+stock+pack_size split (space/equipment vs. consumables) is
// enforced by the `listings_pricing_matches_type` CHECK constraint added in
// migration 20260718171756_listings_pricing_check (raw SQL — Prisma can't
// express this cross-column rule natively).
model Listing {
  id              BigInt      @id @default(autoincrement())
  companyId       BigInt      @map("company_id")
  type            ListingType
  name            String
  location        String?
  description     String?
  imageUrl        String?     @map("image_url")
  amenities       Json?
  isAvailable     Boolean     @default(true) @map("is_available")
  requireApproval Boolean     @default(false) @map("require_approval")
  priceDay        Decimal?    @map("price_day") @db.Decimal(10, 2)
  priceWeek       Decimal?    @map("price_week") @db.Decimal(10, 2)
  priceMonth      Decimal?    @map("price_month") @db.Decimal(10, 2)
  pricePerUnit    Decimal?    @map("price_per_unit") @db.Decimal(10, 2)
  stockQuantity   Int?        @map("stock_quantity")
  packSize        String?     @map("pack_size")
  // Sprint 6.12 — the marketplace's effective "sort as new" timestamp.
  // Starts equal to createdAt (backfilled by this field's own migration for
  // pre-existing rows) and is bumped to now() whenever a Bump is spent on
  // this listing (activateBump, lib/listings.ts) — replaces the previous
  // `orderBy: { id: "asc" }` (oldest-first, not date-based at all, confirmed
  // by reading the route before assuming otherwise). A single field rather
  // than comparing createdAt/updatedAt/a bump-log table at query time — one
  // column Prisma can sort by directly, no raw SQL needed.
  boostedAt       DateTime    @default(now()) @map("boosted_at")
  // Sprint 6.12 — Pins. Nullable pair, null = not pinned (matching this
  // schema's existing nullable-expiry convention, e.g. RewardGrant/
  // SupplierRewardRedemption). pinnedAt orders multiple simultaneously
  // pinned listings (most-recently-pinned first); pinnedUntil is the
  // expiry a purchase set (7 or 30 days, purchaseAndApplyPin,
  // lib/listings.ts). Lazily cleared on every GET /api/listings read (no
  // scheduled-job infra in this codebase — same idiom as
  // getAvailableCreditBalance's credit-hold expiry) rather than checked
  // ad hoc at every call site, so an expired pin can never sort into the
  // marketplace's Pinned tier by accident.
  pinnedAt        DateTime?   @map("pinned_at")
  pinnedUntil     DateTime?   @map("pinned_until")
  createdAt       DateTime    @default(now()) @map("created_at")
  updatedAt       DateTime    @updatedAt @map("updated_at")

  company Company @relation(fields: [companyId], references: [id], onDelete: Cascade)

  requiredCertificates ListingRequiredCertificate[]
  bookings             Booking[]
  bulkOrderRequests    BulkOrderRequest[]
  purchases            Purchase[]
  checkIns             CheckIn[]
  activityLogs         ActivityLog[]
  ratings              Rating[]
  notifications        Notification[]

  @@map("listings")
}

model ListingRequiredCertificate {
  id            BigInt   @id @default(autoincrement())
  listingId     BigInt   @map("listing_id")
  certificateId BigInt   @map("certificate_id")
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  listing     Listing     @relation(fields: [listingId], references: [id], onDelete: Cascade)
  certificate Certificate @relation(fields: [certificateId], references: [id], onDelete: Cascade)

  @@unique([listingId, certificateId])
  @@map("listing_required_certificates")
}

// expiryDate nullable — renewal-by-video flow deferred, column ready (matches
// old schema note).
model UserCertificate {
  id            BigInt    @id @default(autoincrement())
  userId        String    @map("user_id")
  certificateId BigInt    @map("certificate_id")
  earnedDate    DateTime  @map("earned_date") @db.Date
  expiryDate    DateTime? @map("expiry_date") @db.Date
  createdAt     DateTime  @default(now()) @map("created_at")
  updatedAt     DateTime  @updatedAt @map("updated_at")

  user        User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  certificate Certificate @relation(fields: [certificateId], references: [id], onDelete: Cascade)

  @@unique([userId, certificateId])
  @@map("user_certificates")
}

// companyId nullable = platform-authored. certificateId nullable — most
// videos are informational only; only videos backing a tier1_video_quiz
// certificate's self-serve earning path (Sprint 4, Item 4) have one set. Not
// enforced against Certificate.earningMethod at the DB level (same "app-layer
// rule, not a constraint" idiom as Certificate's own approved-only-if-
// referenced rule) — see lib/quiz-attempts.ts.
model TrainingVideo {
  id              BigInt   @id @default(autoincrement())
  companyId       BigInt?  @map("company_id")
  certificateId   BigInt?  @map("certificate_id")
  title           String
  category        String?
  description     String?
  durationSeconds Int?     @map("duration_seconds")
  videoUrl        String?  @map("video_url")
  thumbnailUrl    String?  @map("thumbnail_url")
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  company     Company?     @relation(fields: [companyId], references: [id], onDelete: SetNull)
  certificate Certificate? @relation(fields: [certificateId], references: [id], onDelete: SetNull)

  quizQuestions    QuizQuestion[]
  videoCompletions VideoCompletion[]
  quizAttempts     QuizAttempt[]

  @@map("training_videos")
}

// No createdAt/updatedAt on purpose — only completed_at, matches old schema.
model VideoCompletion {
  id              BigInt   @id @default(autoincrement())
  userId          String   @map("user_id")
  trainingVideoId BigInt   @map("training_video_id")
  completedAt     DateTime @map("completed_at")

  user          User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  trainingVideo TrainingVideo @relation(fields: [trainingVideoId], references: [id], onDelete: Cascade)

  @@unique([userId, trainingVideoId])
  @@map("video_completions")
}

model QuizQuestion {
  id              BigInt   @id @default(autoincrement())
  trainingVideoId BigInt   @map("training_video_id")
  question        String
  position        Int      @default(0)
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  trainingVideo TrainingVideo @relation(fields: [trainingVideoId], references: [id], onDelete: Cascade)
  answers       QuizAnswer[]

  @@map("quiz_questions")
}

// Exactly 4 answers / exactly 1 correct per question is an app-layer rule,
// not a DB constraint (matches old schema).
model QuizAnswer {
  id             BigInt   @id @default(autoincrement())
  quizQuestionId BigInt   @map("quiz_question_id")
  text           String
  isCorrect      Boolean  @default(false) @map("is_correct")
  position       Int      @default(0)
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")

  quizQuestion QuizQuestion @relation(fields: [quizQuestionId], references: [id], onDelete: Cascade)

  @@map("quiz_answers")
}

// companyId nullable, sme_name = subject-matter expert, endorsementName =
// display label carried over from the old schema (ported as-is). certificateId
// is new (Sprint 4, Item 4): the actual FK an enrollment's sign-off issues a
// credential against — endorsementName was never wired to real issuance logic
// in the old app (confirmed unbuilt, see CODEBASEAPI_SUMMARY.md §6), so a
// robust FK is used instead of runtime name-matching against
// Certificate.name (not unique). Nullable — not every session grants a cert.
model TrainingSession {
  id              BigInt   @id @default(autoincrement())
  companyId       BigInt?  @map("company_id")
  certificateId   BigInt?  @map("certificate_id")
  title           String
  smeName         String   @map("sme_name")
  description     String?
  sessionDatetime DateTime @map("session_datetime")
  location        String?
  endorsementName String?  @map("endorsement_name")
  capacity        Int
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  company     Company?     @relation(fields: [companyId], references: [id], onDelete: SetNull)
  certificate Certificate? @relation(fields: [certificateId], references: [id], onDelete: SetNull)

  enrollments  TrainingEnrollment[]
  activityLogs ActivityLog[]

  @@map("training_sessions")
}

// Overlap prevention is enforced by the `bookings_no_overlap` EXCLUDE USING
// gist constraint added in migration 20260718171742_bookings_no_overlap_exclude
// (raw SQL + btree_gist — Prisma can't express EXCLUDE natively). Any status
// other than `cancelled` holds the slot; only cancelled bookings are excluded
// from the overlap check.
//
// 2026-07-20: `credits` (a combined-wallet deduction) repurposed to
// `sgdAmount` — the purchased/earned balance split means a booking is no
// longer paid by deducting any wallet balance at all; it's charged in
// real-time SGD via Stripe (this field is the authoritative charge amount),
// with an optional earnedBalance discount recorded in `earnedCreditsApplied`.
// No purchasedBalance can ever be applied here — that's the whole point of
// the split, see TransactionType's purchased/earned comment. The actual
// Stripe-charge wiring (payment intent creation, earned-spend Transaction in
// the same DB transaction as the Booking create) is still on the old
// combined-ledger debit path as of this schema change — tracked as a
// Sprint 3.5 known gap in SPRINT_PLAN_NEXTJS_REWRITE.md, not rewired here.
//
// 2026-07-21: the gap above is closed — createBookingWithDebit (lib/bookings.ts)
// now creates a real Stripe PaymentIntent for `sgdAmount - earnedCreditsApplied`
// before opening the DB transaction. `earnedCreditsApplied` is resolved by
// redeeming a specific RewardGrant (type `booking_discount_pct`), never a raw
// client-supplied amount — see RewardGrant's own comment.
//
// 2026-07-21 — merchant-of-record, direct-charge cancellation fields. No
// duplicate stripePaymentIntentId column added here — Transaction already
// carries one (set on the booking_payment row createBookingWithDebit writes,
// see lib/bookings.ts), reused as-is rather than denormalizing a second copy
// onto Booking. userRefundPercent/supplierPenaltyPercent are populated by
// lib/booking-payments.ts's two pure calculator functions at whatever future
// cancellation-flow session actually sets cancelledAt/cancelledBy — not
// written by any code yet this session (schema only).
model Booking {
  id                        BigInt              @id @default(autoincrement())
  userId                    String              @map("user_id")
  listingId                 BigInt              @map("listing_id")
  bookingType               BookingType         @map("booking_type")
  startDate                 DateTime            @map("start_date") @db.Date
  endDate                   DateTime            @map("end_date") @db.Date
  sgdAmount                 Decimal             @map("sgd_amount") @db.Decimal(10, 2)
  earnedCreditsApplied      Decimal             @default(0) @map("earned_credits_applied") @db.Decimal(10, 2)
  // Snapshotted at booking creation (see PLATFORM_COMMISSION_PERCENT_BOOKINGS,
  // lib/booking-payments.ts), not a live constant read at cancellation time —
  // same "don't let a later rate change reshuffle an existing booking" design
  // as SupplierPayable.invoicingCadence. Confirmed with the product owner
  // 2026-07-21: flat 10% for space/equipment bookings (consumables/bulk
  // orders use a different, separately-scoped rate).
  platformCommissionPercent Decimal             @default(10) @map("platform_commission_percent") @db.Decimal(5, 2)
  // Sprint 6.5 addition (2026-07-21) — User Reward Tier system. Snapshotted
  // at booking creation from getUserRewardTier (lib/reward-tiers.ts), same
  // "don't let a later change reshuffle an existing booking" discipline as
  // platformCommissionPercent above. Paid out as an earned_grant Transaction
  // at booking completion (grantRewardTierRebate, lib/reward-tiers.ts),
  // not at creation — the tier a user held when they BOOKED is what they're
  // rebated on, even if their tier changes before the stay completes.
  rewardTierRebatePercent   Decimal             @default(1) @map("reward_tier_rebate_percent") @db.Decimal(5, 2)
  status                    BookingStatus       @default(pending)
  cancelledAt               DateTime?           @map("cancelled_at")
  cancelledBy               BookingCancelledBy? @map("cancelled_by")
  cancellationReason        String?             @map("cancellation_reason")
  userRefundPercent         Decimal?            @map("user_refund_percent") @db.Decimal(5, 2)
  supplierPenaltyPercent    Decimal?            @map("supplier_penalty_percent") @db.Decimal(5, 2)
  // Sprint 4.75 addition (2026-07-21) — user-initiated reschedule
  // ("Modify Booking"), see modifyBookingWithFee (lib/bookings.ts) and
  // calculateModificationTerms (lib/booking-payments.ts).
  // originalStartDate is set once, the first time a booking is modified —
  // preserves the pre-modification date for history/audit display even
  // across repeat modifications; startDate/endDate above always hold the
  // CURRENT (possibly-modified) schedule and are what every other part of
  // this codebase (overlap check, cancellation-window day tiers) already
  // reads, unchanged.
  originalStartDate         DateTime?           @map("original_start_date") @db.Date
  // Set true the first time a modification lands in the 3-7 day fee tier
  // (per the product brief's own pseudocode — a free, >7-day-out
  // modification does not set this). Never reset back to false.
  isModified                Boolean             @default(false) @map("is_modified")
  // Caps this booking's OWN later user-initiated cancellation refund (the
  // "Refund Cap Engine": final % = min(standard day-tier %, this value)) —
  // see cancelBookingWithRefund, lib/bookings.ts. Null means uncapped
  // (a never-modified booking behaves exactly as before this feature).
  // Re-set on every modification per the tier that modification landed in
  // (a later free modification restores it to 100, not left at a stale 50).
  maxRefundablePercent      Decimal?            @map("max_refundable_percent") @db.Decimal(5, 2)
  // Sprint 6.5 addition — set once, at check-out (checkOutCheckIn,
  // lib/check-ins.ts), the moment status flips active -> completed.
  // updatedAt is not reliable for this: it bumps on every write to the row
  // (any later, unrelated update would silently shift what "when this
  // completed" means), which the reward-tier rolling-window calculation
  // (getUserRewardTierWindowStats, lib/reward-tiers.ts) needs to be exact
  // about. Null for every booking that hasn't completed (or never will).
  completedAt               DateTime?           @map("completed_at")
  createdAt                 DateTime            @default(now()) @map("created_at")
  updatedAt                 DateTime            @updatedAt @map("updated_at")

  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  listing Listing @relation(fields: [listingId], references: [id], onDelete: Cascade)

  transactions         Transaction[]
  checkIns             CheckIn[]
  rating               Rating?
  bookingCreditsIssued BookingCredit[]      @relation("BookingCreditSource")
  bookingCreditsSpent  BookingCredit[]      @relation("BookingCreditAppliedTo")
  supplierPayable      SupplierPayable?
  notifications        Notification[]
  companyTransactions  CompanyTransaction[]

  @@map("bookings")
}

// New feature (not a port from the old Laravel API — no Review/Rating
// concept existed there). One rating per booking (not per listing), so a
// user booking the same listing multiple times can rate each stay
// separately. listingId is denormalized off the booking at creation time so
// average/count aggregates don't need a join through bookings. score is
// constrained to 1-5 by a CHECK constraint (see the migration), matching
// the star-rating UI already in components/RatingStars.tsx.
model Rating {
  id        BigInt   @id @default(autoincrement())
  bookingId BigInt   @unique @map("booking_id")
  userId    String   @map("user_id")
  listingId BigInt   @map("listing_id")
  score     Int
  comment   String?
  createdAt DateTime @default(now()) @map("created_at")

  booking Booking @relation(fields: [bookingId], references: [id], onDelete: Cascade)
  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  listing Listing @relation(fields: [listingId], references: [id], onDelete: Cascade)

  @@map("ratings")
}

// Activity feed row for one hooked action. Sprint 3.5 new schema item — see
// SPRINT_PLAN_NEXTJS_REWRITE.md's Sprint 3.5 "new schema items" list. No
// updatedAt: rows are append-only, never edited after insert, unlike every
// other model in this file. relatedListingId is nullable because not every
// hooked action ties to a listing (wallet_topup doesn't). No feed UI yet —
// this sprint only wires the write path; verify by querying this table
// directly after performing a hooked action.
model ActivityLog {
  id                       BigInt             @id @default(autoincrement())
  userId                   String             @map("user_id")
  actionType               ActivityActionType @map("action_type")
  description              String
  relatedListingId         BigInt?            @map("related_listing_id")
  // Same idiom as relatedListingId — lets the training_enrolled/
  // training_waitlisted/training_waitlist_approved rows link back to the
  // actual TrainingSession (for a clickable feed entry opening its detail
  // modal) instead of the frontend parsing an id out of the description text.
  relatedTrainingSessionId BigInt?            @map("related_training_session_id")
  createdAt                DateTime           @default(now()) @map("created_at")

  user            User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  listing         Listing?         @relation(fields: [relatedListingId], references: [id], onDelete: SetNull)
  trainingSession TrainingSession? @relation(fields: [relatedTrainingSessionId], references: [id], onDelete: SetNull)

  @@map("activity_log")
}

// Consumables-only counterpart to Booking. Unlike the old Laravel schema,
// this rewrite never supported anonymous requests (no requester_name/
// requester_email — auth was already required by the time this table was
// designed, so those legacy-only columns aren't recreated here; see
// CODEBASEAPI_SUMMARY.md §6 "Fixed during recent sprints"). `credits` is
// NOT NULL from the start (computed at creation, cost = pricePerUnit *
// quantity) — the old schema only reached NOT NULL after a backfill
// migration; this rewrite starts there directly.
model BulkOrderRequest {
  id                      BigInt          @id @default(autoincrement())
  userId                  String          @map("user_id")
  listingId               BigInt          @map("listing_id")
  quantity                Int
  credits                 Decimal         @db.Decimal(10, 2)
  status                  BulkOrderStatus @default(pending)
  // Required at confirm time (2026-07-20 product owner request) — the
  // supplier's estimate of when the order will ship, shown to the buyer.
  // Nullable at the DB level only because pre-existing rows predate this
  // column; app-layer validation requires it on every confirm going forward.
  estimatedDeliveryDate   DateTime?       @map("estimated_delivery_date")
  // Cancellation-request pair, set together and cleared together — 2026-07-20
  // product owner request. Only meaningful while status is `confirmed`: a
  // `pending` request can be cancelled directly by the buyer (no review
  // needed, see cancelBulkOrderByUser in lib/bulk-orders.ts), but a
  // `confirmed` one has already had supplier attention, so the buyer can only
  // ask — the supplier approves (→ cancelled) or rejects (both fields
  // cleared, status stays confirmed).
  cancellationRequestedAt DateTime?       @map("cancellation_requested_at")
  cancellationReason      String?         @map("cancellation_reason")
  createdAt               DateTime        @default(now()) @map("created_at")
  updatedAt               DateTime        @updatedAt @map("updated_at")

  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  listing Listing @relation(fields: [listingId], references: [id], onDelete: Cascade)

  transactions Transaction[]
  creditHold   CreditHold?

  @@map("bulk_order_requests")
}

// One hold per confirmed bulk order (unique bulkOrderRequestId) — a request
// only ever has one hold across its lifetime, created at confirm and released
// exactly once (fulfill/decline/cancellation-approved/lazy expiry). expiresAt
// is fixed at 7 days from creation (product owner decision, 2026-07-20); there
// is no scheduled job anywhere in this codebase, so expiry is enforced lazily
// — every read of a user's available balance first releases that user's own
// expired holds (see releaseExpiredHoldsForUser, lib/credit-holds.ts), not by
// a background process.
model CreditHold {
  id                 BigInt           @id @default(autoincrement())
  userId             String           @map("user_id")
  bulkOrderRequestId BigInt           @unique @map("bulk_order_request_id")
  amount             Decimal          @db.Decimal(10, 2)
  status             CreditHoldStatus @default(active)
  createdAt          DateTime         @default(now()) @map("created_at")
  expiresAt          DateTime         @map("expires_at")
  releasedAt         DateTime?        @map("released_at")

  user             User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  bulkOrderRequest BulkOrderRequest @relation(fields: [bulkOrderRequestId], references: [id], onDelete: Cascade)

  @@index([userId, status])
  @@map("credit_holds")
}

// "Buy Now" is deliberately NOT a BulkOrderRequest — a bulk order is a
// request the supplier still has to act on (pending/confirmed/fulfilled/
// cancelled); Buy Now is an immediate, already-completed sale: stock and
// credits move atomically at creation, there's no supplier-side status to
// transition. `stripePaymentIntentId` on Transaction is where the future
// Stripe invoice/receipt (user gets an invoice, supplier gets a receipt of
// funds — Sprint 6, not built here) will eventually hang; this model itself
// stays payment-provider-agnostic, same as every other credit-affecting
// model in this schema today.
// 2026-07-21: `earnedCreditsApplied` added — same pattern as
// Booking.earnedCreditsApplied (see that field's comment), an optional
// discount line against `credits` (this model's existing full-cost field,
// confirmed unchanged before adding — it was never called `cost`).
// `credits` still covers the full price via purchasedBalance as today;
// this is an additive discount option, not a replacement mechanic — a
// purchase can still be paid entirely from purchasedBalance with this at 0.
//
// 2026-07-21, same session: the write path is wired — createPurchaseWithDebit
// (lib/purchases.ts) now debits purchasedBalance for `credits - earnedCreditsApplied`
// (TransactionType.purchased_spend, replacing the old combined-ledger `purchase`
// type) and, when a RewardGrant (type `free_consumable_unit`) is redeemed,
// writes a matching earned_spend row. Unlike Booking, Purchase stays
// purchasedBalance-funded — consumables are SpaceSnap's own stock, not a
// third-party operator charge, so there's no compliance reason to route this
// through Stripe per-purchase (see TransactionType's purchased/earned comment).
model Purchase {
  id                   BigInt   @id @default(autoincrement())
  userId               String   @map("user_id")
  listingId            BigInt   @map("listing_id")
  quantity             Int
  credits              Decimal  @db.Decimal(10, 2)
  earnedCreditsApplied Decimal  @default(0) @map("earned_credits_applied") @db.Decimal(10, 2)
  createdAt            DateTime @default(now()) @map("created_at")

  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  listing Listing @relation(fields: [listingId], references: [id], onDelete: Cascade)

  transactions Transaction[]

  @@map("purchases")
}

// 2026-07-21 — gigs, schema only (no payment/payout logic here, same as the
// booking write-path deferral last session — see TransactionType comment
// above and the write-path gap tracked in SPRINT_PLAN_NEXTJS_REWRITE.md).
// purchasedSpend is what the poster pays SpaceSnap to post/fulfil the task —
// SpaceSnap is always principal, posting a task never pays another member
// directly (same pattern as every other purchased_spend event). No
// Transaction FK column added here (unlike Booking/BulkOrderRequest/
// Purchase) — deliberately deferred to the write-path session that actually
// creates these rows, not guessed at ahead of it.
model GigTask {
  id             BigInt        @id @default(autoincrement())
  posterId       String        @map("poster_id")
  description    String
  purchasedSpend Decimal       @map("purchased_spend") @db.Decimal(10, 2)
  status         GigTaskStatus @default(open)
  createdAt      DateTime      @default(now()) @map("created_at")
  updatedAt      DateTime      @updatedAt @map("updated_at")

  poster User @relation("GigTaskPoster", fields: [posterId], references: [id], onDelete: Cascade)

  assignments GigAssignment[]

  @@map("gig_tasks")
}

// One row per worker assigned to a GigTask. payoutAmount is the resolved
// SGD-equivalent value at completion regardless of payoutChoice — earned
// credits and SGD are two different settlement rails for the same amount,
// not two different prices. completedAt nullable: set only when the
// assignment finishes (status transition to GigTaskStatus.completed lives on
// the parent GigTask, not duplicated here).
model GigAssignment {
  id           BigInt          @id @default(autoincrement())
  gigTaskId    BigInt          @map("gig_task_id")
  workerId     String          @map("worker_id")
  payoutChoice GigPayoutChoice @map("payout_choice")
  payoutAmount Decimal         @map("payout_amount") @db.Decimal(10, 2)
  completedAt  DateTime?       @map("completed_at")
  createdAt    DateTime        @default(now()) @map("created_at")
  updatedAt    DateTime        @updatedAt @map("updated_at")

  gigTask GigTask @relation(fields: [gigTaskId], references: [id], onDelete: Cascade)
  worker  User    @relation("GigAssignmentWorker", fields: [workerId], references: [id], onDelete: Cascade)

  @@map("gig_assignments")
}

// The wallet ledger — balance is always SUM(amount) WHERE user_id = ?, never
// stored denormalized. bookingId/bulkOrderRequestId/purchaseId nullable
// (topups aren't tied to any of them). Supports one row per credit-affecting
// event (booking create debit, booking confirm, decline/refund credit,
// bulk-order purchase, instant purchase, topup) rather than the old app's
// single create-time-only row.
//
// 2026-07-20: `type` now also carries which of the two split balances a row
// belongs to (purchased_* vs earned_*) or neither (booking_payment) — see
// the purchased/earned balance-split comment on TransactionType above for
// the full reasoning and the two SUM formulas.
model Transaction {
  id                    BigInt          @id @default(autoincrement())
  userId                String          @map("user_id")
  bookingId             BigInt?         @map("booking_id")
  bulkOrderRequestId    BigInt?         @map("bulk_order_request_id")
  purchaseId            BigInt?         @map("purchase_id")
  // 2026-07-21: set on the earned_spend row a grant redemption writes (or, in
  // future, the earned_grant row an issuance flow writes) — ties the ledger
  // movement back to the specific RewardGrant it corresponds to, per that
  // model's own comment. Nullable: most Transaction rows (topups, purchased_spend,
  // booking_payment, refunds) have no grant involved at all.
  rewardGrantId         BigInt?         @map("reward_grant_id")
  // Set on the Transaction rows a BookingCredit's own lifecycle writes — the
  // zero-amount audit row when it's applied to a new booking, and the
  // leftover-refund row if it covered less than the credit's full amount.
  // Same "trace the ledger row back to what authorized it" pattern as
  // rewardGrantId above. Nullable: unrelated to every other Transaction type.
  bookingCreditId       BigInt?         @map("booking_credit_id")
  // Set on the earned_spend row a Rewards Catalogue redemption writes (see
  // lib/reward-redemptions.ts) — same "trace the ledger row back to what
  // authorized it" pattern as rewardGrantId/bookingCreditId above. Nullable:
  // unrelated to every other Transaction type.
  rewardRedemptionId    BigInt?         @map("reward_redemption_id")
  // Sprint 6.10 follow-on (2026-07-23) — schema-only groundwork for the
  // Buyer Organization shared purchased-credit pool. Confirmed with the
  // product owner: when a spend is ever funded from an org's shared pool,
  // the ledger row must record both who did it (userId, always the acting
  // member) and whose pool it drew from (this field) — same "trace the
  // ledger row back to what authorized it" idiom as rewardGrantId/
  // bookingCreditId/rewardRedemptionId above. No write path sets this yet —
  // the pooled-spend flow itself (choosing to fund a booking/purchase from
  // the org rather than personal purchasedBalance) is still undesigned, per
  // BuyerOrganization's own comment.
  buyerOrganizationId   BigInt?         @map("buyer_organization_id")
  type                  TransactionType
  amount                Decimal         @db.Decimal(10, 2)
  stripePaymentIntentId String?         @map("stripe_payment_intent_id")
  description           String?
  createdAt             DateTime        @default(now()) @map("created_at")
  updatedAt             DateTime        @updatedAt @map("updated_at")

  user              User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  booking           Booking?           @relation(fields: [bookingId], references: [id], onDelete: SetNull)
  bulkOrderRequest  BulkOrderRequest?  @relation(fields: [bulkOrderRequestId], references: [id], onDelete: SetNull)
  purchase          Purchase?          @relation(fields: [purchaseId], references: [id], onDelete: SetNull)
  rewardGrant       RewardGrant?       @relation(fields: [rewardGrantId], references: [id], onDelete: SetNull)
  bookingCredit     BookingCredit?     @relation(fields: [bookingCreditId], references: [id], onDelete: SetNull)
  rewardRedemption  RewardRedemption?  @relation(fields: [rewardRedemptionId], references: [id], onDelete: SetNull)
  buyerOrganization BuyerOrganization? @relation(fields: [buyerOrganizationId], references: [id], onDelete: SetNull)

  @@map("transactions")
}

// Sprint 3.5 new schema item. bookingId nullable — not every check-in ties to
// a booking (e.g. a supplier logging a walk-in visit), so the status side
// effect below only applies when it's set. Per the sprint plan note ("the old
// app never had a working controller for this... should decide whether
// check-in updates booking status" — confirmed with the user before building,
// see CLAUDE1.md): check-in flips a `confirmed` booking to `active`,
// check-out flips `active` to `completed` — the two enum values with no other
// writer anywhere in this codebase. Enforced in lib/check-ins.ts, not a DB
// constraint (mirrors how Booking status guards on confirm/decline are
// app-layer, not DB-layer).
model CheckIn {
  id           BigInt    @id @default(autoincrement())
  userId       String    @map("user_id")
  listingId    BigInt    @map("listing_id")
  bookingId    BigInt?   @map("booking_id")
  checkedInAt  DateTime  @default(now()) @map("checked_in_at")
  checkedOutAt DateTime? @map("checked_out_at")

  user    User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  listing Listing  @relation(fields: [listingId], references: [id], onDelete: Cascade)
  booking Booking? @relation(fields: [bookingId], references: [id], onDelete: SetNull)

  @@map("check_ins")
}

// Sprint 3.5 new schema item — backs the training session "enrolled
// participants" list referenced by the Digital Passport / training pages
// (no roster UI built yet this sprint; see SPRINT_PLAN_NEXTJS_REWRITE.md
// Sprint 3.5). One row per user per session, enforced at the DB level (not
// just app-layer) by @@unique below — same "app-layer pre-check + DB
// constraint as race-condition fallback" idiom as bookings_no_overlap (see
// lib/training-enrollments.ts and app/api/bookings/route.ts's 23P01 catch;
// this one catches Postgres 23505 instead).
model TrainingEnrollment {
  id                BigInt                   @id @default(autoincrement())
  userId            String                   @map("user_id")
  trainingSessionId BigInt                   @map("training_session_id")
  status            TrainingEnrollmentStatus @default(enrolled)
  createdAt         DateTime                 @default(now()) @map("created_at")
  updatedAt         DateTime                 @updatedAt @map("updated_at")

  user            User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  trainingSession TrainingSession @relation(fields: [trainingSessionId], references: [id], onDelete: Cascade)

  @@unique([userId, trainingSessionId])
  @@map("training_enrollments")
}

// Sprint 4, Item 4 — the tier1_video_quiz earning path: a user's graded
// submission against a TrainingVideo's quiz. Auto-graded at submission time
// (no reviewer — that's what distinguishes tier1 from the tier2a/2b
// operator/SME sign-off path, which reuses training_enrollments' existing
// status column instead of this table, per the "don't invent new statuses"
// instruction for this item). Append-only like ActivityLog/VideoCompletion —
// retries create a new row rather than overwriting, so the user's full
// attempt history is visible, not just the latest result. No unique
// constraint on (userId, trainingVideoId): retakes after a fail are allowed.
// score/totalQuestions are a snapshot of that attempt's grading, independent
// of any later edits to the quiz's question set. See lib/quiz-attempts.ts.
model QuizAttempt {
  id              BigInt   @id @default(autoincrement())
  userId          String   @map("user_id")
  trainingVideoId BigInt   @map("training_video_id")
  score           Int
  totalQuestions  Int      @map("total_questions")
  passed          Boolean
  createdAt       DateTime @default(now()) @map("created_at")

  user          User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  trainingVideo TrainingVideo @relation(fields: [trainingVideoId], references: [id], onDelete: Cascade)

  @@map("quiz_attempts")
}

// Sprint 4, Item 4 — the tier2a_operator_signoff earning path (see
// SignoffSubmissionType/SignoffRequestStatus comments above). One row per
// (userId, certificateId), not append-only like QuizAttempt: a fresh
// submission after a terminal outcome (passed/failed) updates this same row
// rather than creating a new one, per the product owner's "one record per
// user certificate" instruction. recordingKey is an R2 object key
// (lib/storage.ts), not a public URL — evidence is reviewed, not displayed —
// and is only set when submissionType is `recording`.
model CertificateSignoffRequest {
  id             BigInt                @id @default(autoincrement())
  userId         String                @map("user_id")
  certificateId  BigInt                @map("certificate_id")
  submissionType SignoffSubmissionType @map("submission_type")
  recordingKey   String?               @map("recording_key")
  status         SignoffRequestStatus  @default(pending)
  reviewedBy     String?               @map("reviewed_by")
  reviewedAt     DateTime?             @map("reviewed_at")
  createdAt      DateTime              @default(now()) @map("created_at")
  updatedAt      DateTime              @updatedAt @map("updated_at")

  user        User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  certificate Certificate @relation(fields: [certificateId], references: [id], onDelete: Cascade)
  reviewer    User?       @relation("SignoffReviewer", fields: [reviewedBy], references: [id], onDelete: SetNull)

  @@unique([userId, certificateId])
  @@map("certificate_signoff_requests")
}

// Real notification rows — replaces components/NotificationsPanel.tsx's
// MOCK_NOTIFICATIONS. One value per event actually hooked into (same
// "don't invent a type nothing writes to" discipline as ActivityActionType),
// covering the mock's original four plus the new pinned booking-credit case.
enum NotificationType {
  cert_earned
  cert_expiry
  booking_confirmed
  credit_topup
  // Pinned, not read-state-driven — see Notification.pinned below. Created
  // by declineBookingPendingResolution the moment a supplier decline leaves
  // a real refund unresolved; deleted the moment that resolves (rebooked or
  // refunded), never just marked read. lib/bookings.ts is what writes these.
  booking_credit_pending

  @@map("notification_type")
}

model Notification {
  id                   BigInt            @id @default(autoincrement())
  userId               String            @map("user_id")
  title                String?
  message              String
  type                 NotificationType?
  // Pinned notifications sort first regardless of createdAt and are not
  // cleared by "mark as read" — only by the row being deleted once whatever
  // it's tracking actually resolves (see booking_credit_pending above). Every
  // other notification type leaves this false and behaves like a normal
  // read/unread item.
  pinned               Boolean           @default(false)
  isRead               Boolean           @default(false) @map("is_read")
  relatedBookingId     BigInt?           @map("related_booking_id")
  relatedListingId     BigInt?           @map("related_listing_id")
  // Also used by cert_earned (no dedup needed there — re-earning/renewing a
  // certificate is a genuinely new event each time, so no uniqueness
  // constraint on this column: sweepExpiringCertificateNotifications
  // (lib/notifications.ts) dedups cert_expiry rows with an app-layer
  // findFirst-then-create check instead, deliberately not a DB constraint,
  // since it would otherwise also block a legitimate second cert_earned row.
  relatedCertificateId BigInt?           @map("related_certificate_id")
  createdAt            DateTime          @default(now()) @map("created_at")

  user               User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  relatedBooking     Booking?     @relation(fields: [relatedBookingId], references: [id], onDelete: Cascade)
  relatedListing     Listing?     @relation(fields: [relatedListingId], references: [id], onDelete: SetNull)
  relatedCertificate Certificate? @relation(fields: [relatedCertificateId], references: [id], onDelete: Cascade)

  @@map("notifications")
}

// Sprint 6.12 — admin broadcast, deliberately NOT the Notification model's
// per-recipient-row shape: one shared content row per send (confirmed with
// the product owner — cheap fan-out over duplicating title/message per
// recipient), read-state tracked per user via AnnouncementRead below.
// targetMembers/targetSuppliers are two independent flags chosen at send
// time (not a single enum) — a broadcast can target either or both,
// mirroring AdminEdmCampaign's identical audience shape. App-layer
// validation (lib/announcements.ts) requires at least one true.
model Announcement {
  id              BigInt   @id @default(autoincrement())
  title           String?
  message         String
  targetMembers   Boolean  @default(false) @map("target_members")
  targetSuppliers Boolean  @default(false) @map("target_suppliers")
  createdByUserId String   @map("created_by_user_id")
  createdAt       DateTime @default(now()) @map("created_at")

  createdBy User               @relation("AnnouncementCreatedBy", fields: [createdByUserId], references: [id], onDelete: Cascade)
  reads     AnnouncementRead[]

  @@map("announcements")
}

// Row existence = read, no boolean column — a real idempotent fact (has
// THIS user read THIS announcement), unlike Notification.isRead's flip on a
// per-recipient row. @@unique enforces "at most one read record per
// (announcement, user)" at the DB level, so markAnnouncementRead can be a
// safe upsert against double-clicks.
model AnnouncementRead {
  id             BigInt   @id @default(autoincrement())
  announcementId BigInt   @map("announcement_id")
  userId         String   @map("user_id")
  createdAt      DateTime @default(now()) @map("created_at")

  announcement Announcement @relation(fields: [announcementId], references: [id], onDelete: Cascade)
  user         User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([announcementId, userId])
  @@map("announcement_reads")
}

// Sprint 6.12 — separate feature from the EDM popup below, not the same
// mechanism (confirmed with the product owner): a persistent strip below
// the navbar, not a modal. Two platform-level singletons (Member portal,
// Supplier portal) — admin-only, no supplier self-serve, unlike the EDM
// popup's supplier slot. `portal @unique` makes "save" a literal upsert;
// `expiresAt` nullable = never expires, same convention as
// RewardGrant/SupplierRewardRedemption. Dismissal is client-side
// (localStorage, keyed off id+updatedAt) — no per-user DB tracking, lower
// stakes than the EDM popup's lastEdmSeenAt.
enum BannerPortal {
  member
  supplier

  @@map("banner_portal")
}

model Banner {
  id              BigInt       @id @default(autoincrement())
  portal          BannerPortal @unique
  imageKey        String       @map("image_key")
  expiresAt       DateTime?    @map("expires_at")
  updatedByUserId String       @map("updated_by_user_id")
  createdAt       DateTime     @default(now()) @map("created_at")
  updatedAt       DateTime     @updatedAt @map("updated_at")

  updatedBy User @relation("BannerUpdatedBy", fields: [updatedByUserId], references: [id], onDelete: Cascade)

  @@map("banners")
}

// Sprint 6.12 — the EDM sign-in popup. Two independent authorship slots,
// deliberately two separate models rather than one with a nullable
// companyId discriminator (their shapes genuinely differ — admin's audience
// is a multi-select with no natural unique key; supplier's is hardcoded to
// Members and naturally keyed by companyId). Singleton by app-layer
// convention (setAdminEdmCampaign does a delete-then-create $transaction,
// lib/edm-campaigns.ts) — there's no natural unique key to hang a DB
// constraint on for "the one admin campaign," unlike the supplier slot
// below.
model AdminEdmCampaign {
  id              BigInt   @id @default(autoincrement())
  imageKey        String   @map("image_key")
  caption         String?
  targetMembers   Boolean  @default(true) @map("target_members")
  targetSuppliers Boolean  @default(false) @map("target_suppliers")
  createdByUserId String   @map("created_by_user_id")
  createdAt       DateTime @default(now()) @map("created_at")

  createdBy User @relation("AdminEdmCampaignCreatedBy", fields: [createdByUserId], references: [id], onDelete: Cascade)

  @@map("admin_edm_campaigns")
}

// One row per company, DB-enforced via companyId @unique — "uploading a new
// one replaces the old" is a literal upsert on this key, no app-layer
// deactivation logic needed. Always targets Members only (confirmed with
// the product owner — a supplier's ad to buyers), so there is deliberately
// no audience column here, unlike AdminEdmCampaign above.
model SupplierEdmCampaign {
  id              BigInt   @id @default(autoincrement())
  companyId       BigInt   @unique @map("company_id")
  imageKey        String   @map("image_key")
  caption         String?
  createdByUserId String   @map("created_by_user_id")
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  company   Company @relation(fields: [companyId], references: [id], onDelete: Cascade)
  createdBy User    @relation("SupplierEdmCampaignCreatedBy", fields: [createdByUserId], references: [id], onDelete: Cascade)

  @@map("supplier_edm_campaigns")
}
